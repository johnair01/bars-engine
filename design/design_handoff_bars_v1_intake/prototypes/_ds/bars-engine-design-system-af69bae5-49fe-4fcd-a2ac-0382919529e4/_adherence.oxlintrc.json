{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/cards/**",
              "components/core/**",
              "ui_kits/bars-engine/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Jost|Nunito|Space Mono))/i]",
        "message": "Font not provided by the design system. Available: Jost, Nunito, Space Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|element|altitude|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, variant, element, altitude, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|element|disabled|sigil|fullWidth|type|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, element, disabled, sigil, fullWidth, type, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChromeLabel'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|element|dot|style|key|ref|className|style|children)$/]",
        "message": "<ChromeLabel> doesn't accept that prop. Declared props: children, tone, element, dot, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='CultivationCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:element|altitude|stage|interactive|selected|disabled|loading|ritual|animated|floating|className|style|children|key|ref|className|style|children)$/]",
        "message": "<CultivationCard> doesn't accept that prop. Declared props: element, altitude, stage, interactive, selected, disabled, loading, ritual, animated, floating, className, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='ElementSigil'] > JSXAttribute > JSXIdentifier[name!=/^(?:element|size|framed|glow|style|key|ref|className|style|children)$/]",
        "message": "<ElementSigil> doesn't accept that prop. Declared props: element, size, framed, glow, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ElementSigil'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg|xl)$/]",
        "message": "<ElementSigil> size must be one of 'sm' | 'md' | 'lg' | 'xl'."
      },
      {
        "selector": "JSXOpeningElement[name.name='MoveIcon'] > JSXAttribute > JSXIdentifier[name!=/^(?:move|size|color|title|style|key|ref|className|style|children)$/]",
        "message": "<MoveIcon> doesn't accept that prop. Declared props: move, size, color, title, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='VibulonStat'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|align|size|delta|style|key|ref|className|style|children)$/]",
        "message": "<VibulonStat> doesn't accept that prop. Declared props: value, label, align, size, delta, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='VibulonStat'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:left|right)$/]",
        "message": "<VibulonStat> align must be one of 'left' | 'right'."
      },
      {
        "selector": "JSXOpeningElement[name.name='VibulonStat'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<VibulonStat> size must be one of 'sm' | 'md' | 'lg'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
