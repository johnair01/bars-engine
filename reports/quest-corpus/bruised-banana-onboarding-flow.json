        {
          "type": "read",
          "requires": [
            "observe"
          ],
          "emits": [
            "prompt_viewed"
          ],
          "next_node_id": "Skeptical Response",
          "label": "I'm skeptical. Systems like this rarely work the way people hope."
        }
      ]
    },
    {
