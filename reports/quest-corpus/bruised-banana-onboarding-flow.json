        {
          "type": "read",
          "requires": [
            "observe"
          ],
          "emits": [
            "prompt_viewed"
          ],
          "next_node_id": "Aligned Response",
          "label": "This sounds exciting. I want to see what's possible here."
        },
        {
          "type": "read",
          "requires": [
            "observe"
          ],
          "emits": [
            "prompt_viewed"
          ],
          "next_node_id": "Curious Response",
          "label": "I'm curious, though I'm still figuring out where I fit."
