model LibraryRequest {
  id                   String       @id @default(cuid())
  createdAt            DateTime     @default(now())
  createdById          String
  instanceId           String?
  requestText          String
  requestType          String       @default("other") // rules, ux, tech, lore, social, other
  privacy              String       @default("anonymized") // private, anonymized, public
  contextJson          String? // JSON: screen, questId, actionId, etc.
  status               String       @default("new") // new, resolved, spawned, closed
  resolvedDocNodeId    String?
  spawnedBacklogItemId String?      @unique
  spawnedDocQuestId    String?      @unique
  createdBy            Player       @relation(fields: [createdById], references: [id], onDelete: Cascade)
  instance             Instance?    @relation(fields: [instanceId], references: [id], onDelete: SetNull)
  resolvedDocNode      DocNode?     @relation("LibraryRequestResolved", fields: [resolvedDocNodeId], references: [id], onDelete: SetNull)
  spawnedBacklogItem   BacklogItem? @relation("BacklogItemSpawnedBy", fields: [spawnedBacklogItemId], references: [id], onDelete: SetNull)
  spawnedDocQuest      CustomBar?   @relation("LibraryRequestSpawnedQuest", fields: [spawnedDocQuestId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([instanceId, createdAt])
  @@map("library_requests")
}

model DocNode {
  id                  String            @id @default(cuid())
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  nodeType            String            @default("handbook") // handbook, codex, lore, request_record
  title               String
  slug                String            @unique
  scope               String            @default("experimental") // local, campaign, global, experimental, deprecated
  versionMin          String?
  versionMax          String?
  buildHash           String?
  tags                String            @default("[]") // JSON array
  bodyRst             String?           @db.Text
  bodySource          String            @default("curated") // generated, curated
  canonicalStatus     String            @default("draft") // draft, validated, canonical, deprecated
  mergedIntoDocNodeId String?
  provenanceJson      String? // JSON: libraryRequestId, questIds, barIds, instanceIds
  mergedInto          DocNode?          @relation("DocNodeMerge", fields: [mergedIntoDocNodeId], references: [id], onDelete: SetNull)
  mergedFrom          DocNode[]         @relation("DocNodeMerge")
  resolvedRequests    LibraryRequest[]  @relation("LibraryRequestResolved")
  evidenceLinks       DocEvidenceLink[]

  @@index([canonicalStatus, scope])
  @@index([slug])
  @@map("doc_nodes")
}

model DocEvidenceLink {
