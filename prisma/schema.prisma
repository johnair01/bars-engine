  hexagramSequence String   @default("[]")
  updatedAt        DateTime @updatedAt

  @@map("global_state")
}

model StoryTick {
  id          String   @id @default(cuid())
  tickNumber  Int
  actNumber   Int
  trigger     String
  description String
  createdAt   DateTime @default(now())

  @@map("story_ticks")
}

model TwineStory {
