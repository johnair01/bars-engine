/// Master of Friendship: High-trust phone-based invitations using friendship deck cards
model FriendshipInvitation {
  id                 String    @id @default(cuid())
  senderId           String
  friendPhone        String? // High-trust contact info (optional, for analytics)
  cardId             String // BarDeckCard used for this invitation
