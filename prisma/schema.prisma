  isCanon    Boolean  @default(false)
  createdAt  DateTime @default(now())

  npc    NpcConstitution @relation(fields: [npcId], references: [id], onDelete: Cascade)
  player Player?         @relation(fields: [playerId], references: [id], onDelete: SetNull)

  @@index([npcId])
  @@index([npcId, playerId])
  @@map("npc_memories")
}

model NpcReflection {
  id           String    @id @default(cuid())
  npcId        String
  campaignId   String?
  inputSummary String
  outputs      String // JSON: stance_update, possible_hooks[], bar_affinity_shift[]
  status       String    @default("pending") // pending|approved|rejected
  reviewedBy   String?
  reviewedAt   DateTime?
  createdAt    DateTime  @default(now())

  npc NpcConstitution @relation(fields: [npcId], references: [id], onDelete: Cascade)

  @@index([npcId, status])
  @@map("npc_reflections")
}

model NpcAction {
  id                     String   @id @default(cuid())
  npcId                  String
  sceneId                String?
  verb                   String // reveal_lore|ask_question|challenge_player|affirm_player|offer_quest_seed|reflect_bar|redirect_scene|deepen_scene|handoff_to_other_npc
  payload                String // JSON
  requiresRegentApproval Boolean  @default(false)
  status                 String   @default("executed") // executed|blocked|pending
  reason                 String?
  createdAt              DateTime @default(now())

  npc NpcConstitution @relation(fields: [npcId], references: [id], onDelete: Cascade)

  @@index([npcId])
  @@map("npc_actions")
}

model NpcRelationshipState {
  id         String   @id @default(cuid())
  npcId      String
  playerId   String
  campaignId String?
  trust      Int      @default(0) // -100 to 100
  tension    Int      @default(0) // 0 to 100
  state      String   @default("{}") // JSON: freeform relational metadata
  updatedAt  DateTime @updatedAt

  npc    NpcConstitution @relation(fields: [npcId], references: [id], onDelete: Cascade)
  player Player          @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([npcId, playerId])
  @@map("npc_relationship_states")
}

model SpatialMap {
  id                     String              @id @default(cuid())
  name                   String
  instanceId             String?             @map("instance_id")
  mapType                String              @map("map_type") // campaign_map | encounter | lobby
  spawnpoint             String // JSON: { roomIndex, x, y }
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  rooms                  MapRoom[]
  presences              PlayerMapPresence[]
  linkedInstances        Instance[]          @relation("InstanceSpatialMap")
  defaultLobbyMapConfigs AppConfig[]         @relation("DefaultLobbyMap")

  @@map("spatial_maps")
}

model PlayerMapPresence {
  id        String     @id @default(cuid())
  playerId  String     @map("player_id")
  mapId     String     @map("map_id")
  roomIndex Int        @map("room_index")
  x         Int
  y         Int
  direction String     @default("south") // north | south | east | west
  updatedAt DateTime   @updatedAt
  player    Player     @relation(fields: [playerId], references: [id], onDelete: Cascade)
  map       SpatialMap @relation(fields: [mapId], references: [id], onDelete: Cascade)

  @@unique([playerId, mapId])
  @@index([mapId])
  @@map("player_map_presences")
}

model MapRoom {
  id                String             @id @default(cuid())
  mapId             String             @map("map_id")
  map               SpatialMap         @relation(fields: [mapId], references: [id], onDelete: Cascade)
  name              String
  slug              String             @default("") @map("slug")
  tilemap           String // JSON: { "x, y": { floor?, above_floor?, object?, impassable?, teleporter? } }
  graphNodeId       String?            @map("graph_node_id") // Links to Twine passage ID or campaign map node ID
  channelId         String?            @map("channel_id") // For video chat if used later
  sortOrder         Int                @default(0) @map("sort_order")
  // BAR Lobby World fields (LW-2)
  roomType          String?            @map("room_type") // nation_room | trading_floor | embassy
  nationKey         String?            @map("nation_key") // pyrakanth | lamenth | virelune | argyra | meridia | null (trading floor)
  backgroundUrl     String?            @map("background_url") // public/lobby-art/{slug}.png
  anchors           SpatialMapAnchor[]
  presences         RoomPresence[]
  tradeTransactions TradeTransaction[]
  starterBARs       StarterBAR[]

  @@unique([mapId, slug])
  @@index([mapId])
  @@map("map_rooms")
}

model SpatialMapAnchor {
  id         String   @id @default(cuid())
  roomId     String   @map("room_id")
  room       MapRoom  @relation(fields: [roomId], references: [id], onDelete: Cascade)
  anchorType String   @map("anchor_type")
  tileX      Int      @map("tile_x")
  tileY      Int      @map("tile_y")
  label      String?
  linkedId   String?  @map("linked_id")
  linkedType String?  @map("linked_type")
  config     String?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([roomId])
  @@map("spatial_map_anchors")
}

model RoomPresence {
  id           String   @id @default(cuid())
  playerId     String   @map("player_id")
  roomId       String   @map("room_id")
  instanceSlug String   @map("instance_slug")
  enteredAt    DateTime @default(now()) @map("entered_at")
  lastSeenAt   DateTime @updatedAt @map("last_seen_at")

  player Player  @relation(fields: [playerId], references: [id], onDelete: Cascade)
  room   MapRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([playerId, roomId])
  @@index([roomId, lastSeenAt])
  @@map("room_presence")
}

model SpriteAuditLog {
  id           String   @id @default(cuid())
  playerId     String
  pipeline     String // "portrait" | "walkable"
  nationKey    String
  archetypeKey String
  status       String // "enqueued" | "generated" | "review" | "approved" | "rejected"
  attempt      Int      @default(1)
  promptUsed   String?
  sourceModel  String? // "dalle3" | "stability" | "lpc" | "manual"
  reviewNote   String?
  lpcBaseAsset String? // for walkable: LPC base asset used (attribution)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ── Phase 3: Cultural Substrate Pipeline ─────────────────────────────────────

model PlayerAlignment {
  id        String   @id @default(cuid())
  playerId  String   @unique
  counts    String   @default("{}") // JSON: { [moveType_domain_face_tag]: count }
  updatedAt DateTime @updatedAt

  player Player @relation(fields: [playerId], references: [id])

  @@map("player_alignments")
}

model CarriedWeight {
  id               String    @id @default(cuid())
  playerId         String
  beliefText       String
  shadowName       String?
  source           String // shadow_name_session | voluntary_pickup | face_named
  status           String    @default("held") // held | in_play | metabolized | set_down
  loadLevel        Int       @default(1) // 1 | 2 | 3
  heldSince        DateTime  @default(now())
  metabolizedAt    DateTime?
  metabolizedBarId String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  player         Player     @relation(fields: [playerId], references: [id])
  metabolizedBar CustomBar? @relation("CarriedWeightBar", fields: [metabolizedBarId], references: [id], onDelete: SetNull)

  @@index([playerId, status])
  @@map("carried_weights")
}

model DistillationCandidate {
  id                    String    @id @default(cuid())
  moveType              String?
  archetype             String?
  allyshipDomain        String?
  nationKey             String?
  sourceBarIds          String // JSON array of CustomBar ids
  clusterSize           Int
  secondRegisterName    String
  internalExpr          String
  interpersonalExpr     String
  systemicExpr          String
  episodeTitleCandidate String?
  aiReasoning           String?
  status                String    @default("pending") // pending | approved | rejected | edited
  approvedName          String?
  reviewedAt            DateTime?
  reviewedById          String?
  runId                 String
  createdAt             DateTime  @default(now())

  @@index([status, createdAt])
  @@map("distillation_candidates")
}

// ── NPC Governance Layer ──────────────────────────────────────────────────────

model NpcProfile {
  id               String    @id @default(cuid())
  playerId         String    @unique
  constitutionId   String?   @unique // → NpcConstitution (created lazily on first chat)
  altitude         String // shaman | challenger | regent | architect | diplomat | sage
  tier             Int       @default(1) // 1-4 constitutional depth
  weeklyBudget     Int       @default(10000) // max tokens per week
  tokensUsed       Int       @default(0)
  budgetResetAt    DateTime  @default(now())
  dormantUntil     DateTime? // set when budget exhausted; NPC unavailable until then
  sourceInstanceId String? // origin instance for portability (fork/translate)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  player       Player           @relation(fields: [playerId], references: [id])
  constitution NpcConstitution? @relation(fields: [constitutionId], references: [id], onDelete: SetNull)

  @@map("npc_profiles")
}

// ── BAR Lobby World (LW-2) ────────────────────────────────────────────────────

model TradeTransaction {
  id            String   @id @default(cuid())
  initiatorId   String   @map("initiator_id") // player who offered
  agentId       String   @map("agent_id") // player whose BAR was received
  offeredBarId  String   @map("offered_bar_id")
  receivedBarId String   @map("received_bar_id")
  roomId        String   @map("room_id")
  roomSlug      String   @map("room_slug")
  completedAt   DateTime @default(now()) @map("completed_at")

  initiator Player  @relation("TradeInitiator", fields: [initiatorId], references: [id])
  agent     Player  @relation("TradeAgent", fields: [agentId], references: [id])
  room      MapRoom @relation(fields: [roomId], references: [id])

  @@index([initiatorId, completedAt])
  @@index([roomId, completedAt])
  @@map("trade_transactions")
}

model StarterBAR {
  id        String   @id @default(cuid())
  playerId  String   @map("player_id")
  roomId    String   @map("room_id")
  roomSlug  String   @map("room_slug")
  barId     String   @map("bar_id") // the CustomBar granted
  grantedAt DateTime @default(now()) @map("granted_at")

  player Player  @relation(fields: [playerId], references: [id])
  room   MapRoom @relation(fields: [roomId], references: [id])

  // One starter BAR per player per room per session — enforced at application layer;
  // unique constraint per player+room prevents double-grant across sessions.
  @@unique([playerId, roomId])
  @@index([playerId])
  @@map("starter_bars")
}

// ──────────────────────────────────────────────────────────────
// World Map — Campaign Deck, Periods, Portals, Spoke Sessions,
//             Milestones, Milestone Contributions  (WMC)
// ──────────────────────────────────────────────────────────────

/// Creator-authored deck card. One per hexagram slot a campaign author wants to use.
/// Cards are the source pool; they become CampaignPortals when a period is drawn.
model CampaignDeckCard {
  id                String  @id @default(cuid())
  campaignRef       String // e.g. bruised-banana
  hexagramId        Int // 1–64
  theme             String? // short portal label
  domain            String? // GATHERING_RESOURCES | DIRECT_ACTION | etc.
  cyoaAdventureId   String? // FK → Adventure (resolved at portal hydration)
  questId           String? // FK → CustomBar (the "Raise the Urgency" quest for this portal)
  createdByPlayerId String
  status            String  @default("draft") // draft | active

  createdAt DateTime @default(now())

  createdBy Player           @relation("DeckCardAuthor", fields: [createdByPlayerId], references: [id], onDelete: Cascade)
  portals   CampaignPortal[]

  @@unique([campaignRef, hexagramId]) // one card per hexagram per campaign
  @@index([campaignRef, status])
  @@map("campaign_deck_cards")
}

/// A campaign period — 8 deck cards drawn, no repeats across periods.
/// Period transition is manual (admin triggers drawPeriod).
model CampaignPeriod {
  id           String    @id @default(cuid())
  campaignRef  String
  instanceId   String?
  periodNumber Int // sequential, starts at 1
  kotterStage  String? // urgency | coalition | vision | empower | wins | sustain | culture
  status       String    @default("active") // active | closed
  drawnCardIds String    @default("[]") // JSON array of CampaignDeckCard ids (8 items)
  startedAt    DateTime  @default(now())
  endedAt      DateTime?
  createdAt    DateTime  @default(now())

  instance Instance?        @relation("CampaignPeriods", fields: [instanceId], references: [id], onDelete: SetNull)
  portals  CampaignPortal[]

  @@unique([campaignRef, periodNumber])
  @@index([campaignRef, status])
  @@map("campaign_periods")
}

/// A physical portal entry on the campaign hub page.
/// Created (8 per period) when an admin calls drawPeriod.
model CampaignPortal {
  id              String   @id @default(cuid())
  periodId        String
  campaignRef     String
  slotIndex       Int // 0–7
  hexagramId      Int?
  deckCardId      String?
  cyoaAdventureId String? // resolved from deck card
  questId         String? // "Raise the Urgency" quest for this portal
  completionCount Int      @default(0)
  createdAt       DateTime @default(now())

  period   CampaignPeriod    @relation(fields: [periodId], references: [id], onDelete: Cascade)
  deckCard CampaignDeckCard? @relation(fields: [deckCardId], references: [id], onDelete: SetNull)
  sessions SpokeSession[]

  @@unique([periodId, slotIndex])
  @@index([campaignRef, periodId])
  @@map("campaign_portals")
}

/// A player's journey through one portal's CYOA spoke.
/// Replaces the retired gameboard completion surface for campaign-spoke play.
model SpokeSession {
  id               String    @id @default(cuid())
  portalId         String
  playerId         String
  campaignRef      String
  moveType         String? // wakeUp | cleanUp | growUp | showUp
  gmFace           String? // shaman | regent | challenger | architect | diplomat | sage
  status           String    @default("in_progress") // in_progress | completed | abandoned
  barSeedIds       String    @default("[]") // JSON array of CustomBar ids emitted
  generatedQuestId String? // FK → PlayerQuest (personal quest spawned at spoke end)
  moveChosenAt     DateTime?
  faceChosenAt     DateTime?
  completedAt      DateTime?
  createdAt        DateTime  @default(now())
  intakeCheckInId  String? // FK → AlchemyCheckIn; set by completeIntakeSession

  portal        CampaignPortal  @relation(fields: [portalId], references: [id], onDelete: Cascade)
  player        Player          @relation("SpokeSessions", fields: [playerId], references: [id], onDelete: Cascade)
  barSeeds      CustomBar[]     @relation("SpokeBarSeeds")
  intakeCheckIn AlchemyCheckIn? @relation("SpokeSessionCheckIn", fields: [intakeCheckInId], references: [id], onDelete: SetNull)
  npcEncounters NpcEncounter[]  @relation("NpcEncounters")

  @@index([portalId, playerId])
  @@index([playerId, status])
  @@index([intakeCheckInId])
  @@map("spoke_sessions")
}

/// A public campaign goal, player-proposed and admin-approved.
/// Tracks aggregate progress toward a named outcome.
model CampaignMilestone {
  id                 String    @id @default(cuid())
  campaignRef        String
  title              String
  description        String?   @db.Text
  targetValue        Float? // e.g. dollar amount for donation milestones
  currentValue       Float     @default(0)
  status             String    @default("proposed") // proposed | active | complete
  proposedByPlayerId String
  approvedByPlayerId String?
  approvedAt         DateTime?
  createdAt          DateTime  @default(now())

  proposedBy    Player                  @relation("MilestoneProposals", fields: [proposedByPlayerId], references: [id], onDelete: Cascade)
  approvedBy    Player?                 @relation("MilestoneApprovals", fields: [approvedByPlayerId], references: [id], onDelete: SetNull)
  contributions MilestoneContribution[]

  @@index([campaignRef, status])
  @@map("campaign_milestones")
}

/// A contribution toward a CampaignMilestone (donation, pledge, action).
model MilestoneContribution {
  id            String   @id @default(cuid())
  milestoneId   String
  playerId      String
  barId         String? // FK → CustomBar (the tended BAR seed linked to this contribution)
  donationRef   String? // external payment/donation reference
  value         Float // contribution weight or dollar amount
  note          String?
  contributedAt DateTime @default(now())

  milestone CampaignMilestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  player    Player            @relation("MilestoneContributions", fields: [playerId], references: [id], onDelete: Cascade)

  @@index([milestoneId])
  @@index([playerId])
  @@map("milestone_contributions")
}

/// Lightweight join: one NPC slot injected into a spoke CYOA session.
/// Created at first-hit NPC slot injection; questId set when NPC quest seed is emitted.
/// No full PlayerPlaybook overhead — this is a structural join only.
model NpcEncounter {
  id                 String    @id @default(cuid())
  spokeSessionId     String
  npcId              String // FK → NpcConstitution
  questId            String? // FK → CustomBar (NPC quest seed, set after slot injection)
  departurePassageId String // passage node in spoke CYOA where NPC slot fires
  completedAt        DateTime?
  createdAt          DateTime  @default(now())

  spokeSession SpokeSession    @relation("NpcEncounters", fields: [spokeSessionId], references: [id], onDelete: Cascade)
  npc          NpcConstitution @relation("NpcEncounterNpc", fields: [npcId], references: [id], onDelete: Cascade)

  @@index([spokeSessionId])
  @@index([npcId])
  @@map("npc_encounters")
}

// Wiki Draft for agent-generated documentation
model WikiDraft {
  id                          String   @id @default(cuid())
  artifactId                  String
  artifactType                String
  title                       String
  summary                     String   @db.Text
  provenanceExplanation       String   @db.Text
  relationshipDocumentation   String   @db.Text
  usageExamples               String   @db.Text // JSON array
  metadata                    String   @db.Text // JSON object
  status                      String   @default("pending") // pending, approved, rejected
  reviewNotes                 String?  @db.Text
  reviewedBy                  String?
  reviewedAt                  DateTime?
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  @@index([artifactId])
  @@index([status])
  @@map("wiki_drafts")
}
