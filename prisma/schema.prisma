  phase2Snapshot    String // JSON: q1, q5, alignedAction, moveType
  outcome           String // bar_created | quest_created | fueled_system | skipped | daemon_awakened
  linkedBarId       String?
  linkedQuestId     String?
  /// When set, 321 was launched from this charge_capture BAR; metabolizing outcomes archive the charge.
  chargeSourceBarId String?
  questCompletedAt  DateTime?
  /// Final shadow name when the player completed / preserved the naming step (321 Face It name field).
  finalShadowName   String?
  /// suggested_accepted | edited | typed_no_suggest — how the final name relates to suggest-name clicks.
  nameResolution    String?
  /// Number of times the player clicked "Suggest name" before resolving (0 = typed without using suggest).
