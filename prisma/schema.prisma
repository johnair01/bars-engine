generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

model Invite {
  id                   String                @id @default(cuid())
  token                String                @unique
  status               String                @default("active")
  preassignedRoleKey   String?
  maxUses              Int                   @default(1)
  uses                 Int                   @default(0)
  theme                String                @default("standard")
  createdAt            DateTime              @default(now())
  usedAt               DateTime?
  forgerId             String? // Player who forged/sent the invitation
  invitationTargetType String? // nation | school | sect
  invitationTargetId   String? // nationId, face key (shaman, etc.), or sectId
  instanceId           String? // Golden path: campaign (Instance) to join
  starterQuestId       String? // Golden path: starter quest (CustomBar)
  invitationBarId      String? // Golden path: optional invitation BAR
  invitationMessage    String? // INV-6: forger's personal message ("What do you see in this person...")
  campaignId           String? // Campaign-specific invite link (self-serve)
  forger               Player?               @relation("InvitesForged", fields: [forgerId], references: [id], onDelete: SetNull)
  players              Player[]              @relation("InviteUsed")
  invitationBars       CustomBar[]           @relation("InvitationBar")
  instance             Instance?             @relation(fields: [instanceId], references: [id], onDelete: SetNull)
  starterQuest         CustomBar?            @relation("InviteStarterQuest", fields: [starterQuestId], references: [id], onDelete: SetNull)
  invitationBar        CustomBar?            @relation("InviteInvitationBar", fields: [invitationBarId], references: [id], onDelete: SetNull)
  campaign             Campaign?             @relation("CampaignInvites", fields: [campaignId], references: [id], onDelete: SetNull)
  demoOrientationLinks DemoOrientationLink[]

  @@map("invites")
}

/// Shareable pre-signup orientation slice (DOP). See .specify/specs/demo-orientation-preview/spec.md
model DemoOrientationLink {
  id          String    @id @default(cuid())
  token       String    @unique
  publicSlug  String?   @unique
  adventureId String
  startNodeId String
  campaignRef String?
  instanceId  String?
  inviteId    String?
  maxSteps    Int?
  endNodeId   String?
  expiresAt   DateTime?
  revokedAt   DateTime?
  label       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  adventure Adventure @relation(fields: [adventureId], references: [id], onDelete: Cascade)
  instance  Instance? @relation(fields: [instanceId], references: [id], onDelete: SetNull)
  invite    Invite?   @relation(fields: [inviteId], references: [id], onDelete: SetNull)

  @@index([adventureId])
  @@map("demo_orientation_links")
}

model Player {
  id                             String                      @id @default(cuid())
  accountId                      String?
  name                           String
  creatorType                    String                      @default("human") // human | agent — NPC/simulated player content ecology
  contactType                    String
  contactValue                   String
  passwordHash                   String?
  onboardingMode                 String?                     @default("expert")
  onboardingComplete             Boolean                     @default(false)
  storyProgress                  String?
  hasSeenWelcome                 Boolean                     @default(false)
  hasSeenCampaignEntry           Boolean                     @default(false)
  hasCompletedFirstQuest         Boolean                     @default(false)
  hasCreatedFirstQuest           Boolean                     @default(false)
  onboardingCompletedAt          DateTime?
  inviteId                       String
  invitedByPlayerId              String? // Who invited this player (for analytics, "invited by X")
  nationId                       String?
  archetypeId                    String?
  campaignDomainPreference       String? // JSON array: ["GATHERING_RESOURCES","DIRECT_ACTION"]; null or [] = show all
  avatarConfig                   String? // JSON: { nationKey, archetypeKey, domainKey, variant } derived from CYOA choices
  avatarSpritePath               String? // /sprites/avatar/{nationKey}-{archetypeKey}-{layer}.png (portrait bust, set after generation approved)
  walkableSpritePath             String? // /sprites/walkable/{nationKey}-{archetypeKey}.png (set after walkable approved)
  pronouns                       String?
  attendance                     String?
  gmFaceLevel                    Int                         @default(1) // Level 1 (Shaman) up to Level 6 (Sage)
  createdAt                      DateTime                    @default(now())
  barSharesSent                  BarShare[]                  @relation("BarSharesSent")
  barSharesReceived              BarShare[]                  @relation("BarSharesReceived")
  barShareExternalsSent          BarShareExternal[]          @relation("BarShareExternalsSent")
  barShareExternalsClaimed       BarShareExternal[]          @relation("BarShareExternalsClaimed")
  barTopics                      BarTopic[]
  claimedBars                    CustomBar[]                 @relation("ClaimedBars")
  createdBars                    CustomBar[]                 @relation("CreatedBars")
  donations                      Donation[]
  emotionalAidSessions           EmotionalFirstAidSession[]
  instanceMemberships            InstanceMembership[]
  bars                           PlayerBar[]
  nationMoveUnlocks              PlayerNationMoveUnlock[]
  moveEquips                     PlayerMoveEquip[]
  moveUses                       MoveUse[]
  barResponses                   BarResponse[]
  quests                         PlayerQuest[]
  roles                          PlayerRole[]
  account                        Account?                    @relation(fields: [accountId], references: [id])
  invite                         Invite                      @relation("InviteUsed", fields: [inviteId], references: [id])
  invitedBy                      Player?                     @relation("PlayerInvites", fields: [invitedByPlayerId], references: [id], onDelete: SetNull)
  playersInvited                 Player[]                    @relation("PlayerInvites")
  invitesForged                  Invite[]                    @relation("InvitesForged")
  nation                         Nation?                     @relation(fields: [nationId], references: [id])
  archetype                      Archetype?                  @relation(fields: [archetypeId], references: [id])
  questMoveLogs                  QuestMoveLog[]
  starterPack                    StarterPack?
  twineBindingsCreated           TwineBinding[]              @relation("TwineBindingsCreated")
  twineRunsPlayed                TwineRun[]                  @relation("TwineRunsPlayed")
  twineStoriesCreated            TwineStory[]                @relation("TwineStoriesCreated")
  vibulonEvents                  VibulonEvent[]
  vibulons                       Vibulon[]
  creatorVibulons                Vibulon[]                   @relation("VibulonCreator")
  vibeulonLedger                 VibeulonLedger[]
  participations                 InstanceParticipation[]
  adventureProgress              PlayerAdventureProgress[]
  redemptionPacks                RedemptionPack[]
  libraryRequests                LibraryRequest[]
  bookAnalysisResumeLogs         BookAnalysisResumeLog[]
  verificationCompletionLogs     VerificationCompletionLog[]
  stewardedSlots                 GameboardSlot[]             @relation("GameboardSteward")
  gameboardBids                  GameboardBid[]
  gameboardAidOffersMade         GameboardAidOffer[]         @relation("GameboardAidOfferer")
  gameboardAidOffersReceived     GameboardAidOffer[]         @relation("GameboardAidSteward")
  questProposals                 QuestProposal[]
  bountyStakes                   BountyStake[]
  shadow321Sessions              Shadow321Session[]
  eventArtifactsCreated          EventArtifact[]             @relation("EventArtifactCreator")
  eventParticipations            EventParticipant[]          @relation("EventParticipantAsParticipant")
  eventInvitesReceived           EventInvite[]               @relation("EventInviteReceived")
  eventInvitesSent               EventInvite[]               @relation("EventInviteSent")
  orientationSessions            OrientationSession[]
  daemons                        Daemon[]
  daemonSummons                  DaemonSummon[]
  blessedObjectsEarned           BlessedObjectEarned[]
  playerPlaybooks                PlayerPlaybook[]
  alchemyPlayerState             AlchemyPlayerState?
  alchemySceneEvents             AlchemySceneEvent[]
  npcMemories                    NpcMemory[]
  npcRelationships               NpcRelationshipState[]
  growthScenes                   GrowthScene[]
  alchemyCheckIns                AlchemyCheckIn[]
  thresholdEncounters            ThresholdEncounter[]
  instanceExportRequests         InstanceExportRequest[]
  assets                         Asset[]
  mapPresences                   PlayerMapPresence[]
  spriteUrl                      String?                     @map("sprite_url")
  roomPresences                  RoomPresence[]
  lastForgeTimestamp             DateTime? // Admin Agent Forge: cooldown start
  forgeSessions                  ForgeSession[]
  profileSpatialMap              ProfileSpatialMap?
  alignment                      PlayerAlignment?
  carriedWeights                 CarriedWeight[]
  npcProfile                     NpcProfile?
  npc321InnerWorkMergesAsHuman   Npc321InnerWorkMerge[]      @relation("Npc321InnerWorkMergeHuman")
  npc321InnerWorkMergesAsNpc     Npc321InnerWorkMerge[]      @relation("Npc321InnerWorkMergeNpc")
  daemonPromotedFrom             Daemon[]                    @relation("DaemonPromotedToNpc")
  compostLedgers                 CompostLedger[]
  sceneAtlasGuidedDrafts         SceneAtlasGuidedDraft[]
  playerPromptHand               PlayerPromptHand?
  promptDeckCycles               PromptDeckCycle[]
  // BAR Lobby World (LW-2)
  tradesInitiated                TradeTransaction[]          @relation("TradeInitiator")
  tradesAsAgent                  TradeTransaction[]          @relation("TradeAgent")
  starterBARsGranted             StarterBAR[]
  // WMC — World Map Campaign Deck
  deckCardsAuthored              CampaignDeckCard[]          @relation("DeckCardAuthor")
  spokeSessions                  SpokeSession[]              @relation("SpokeSessions")
  milestonesProposed             CampaignMilestone[]         @relation("MilestoneProposals")
  milestonesApproved             CampaignMilestone[]         @relation("MilestoneApprovals")
  milestoneContributions         MilestoneContribution[]     @relation("MilestoneContributions")
  marketplaceProfiles            PlayerMarketplaceProfile[]
  friendshipInvitationsSent      FriendshipInvitation[]      @relation("FriendshipInvitationsSent")
  friendshipInvitationsCompleted FriendshipInvitation[]      @relation("FriendshipInvitationsCompleted")
  eventBingoCards                EventBingoCard[]
  latentAllyshipIntakes          LatentAllyshipIntake[]
  allyshipIntakesWatered         LatentAllyshipIntake[]      @relation("AllyshipIntakeWateredBy")
  /// K-space / player feedback: BacklogItem rows submitted by this player
  submittedBacklogItems          BacklogItem[]               @relation("BacklogItemSubmittedBy")
  /// SMB: first-mover anchor on spoke move bed
  spokeMoveBedsAnchored          SpokeMoveBed[]              @relation("SpokeMoveBedAnchoredBy")
  spokeMoveBedKernelsPlanted     SpokeMoveBedKernel[]        @relation("SpokeMoveBedKernelPlantedBy")
  /// CCV: GM-authored contribution annotations created by this player
  contributionAnnotationsCreated ContributionAnnotation[]    @relation("ContributionAnnotationCreatedBy")
  /// CCV: Campaign slots created by this player
  campaignSlotsCreated           CampaignSlot[]              @relation("CampaignSlotCreatedBy")
  /// CCV: Player's contribution records across campaigns
  contributionRecords            ContributionRecord[]        @relation("PlayerContributions")
  cmaGeneratorDrafts             CmaGeneratorDraft[]
  /// CSS: Campaigns created by this player (Steward+ only)
  campaignsCreated               Campaign[]                  @relation("CampaignsCreated")
  /// CSS: Campaigns approved by this player (Admin only)
  campaignsReviewed              Campaign[]                  @relation("CampaignsReviewed")
  /// L3: Lore entries authored by this player (empty until L3 ships).
  /// Tracks authorship for narrative sovereignty audit trail — see CampaignLoreEntry model.
  loreEntriesCreated             CampaignLoreEntry[]         @relation("LoreEntriesCreated")

  @@unique([contactType, contactValue])
  @@map("players")
}

/// Vault compost sessions — salvage payload for future “hard compost” organizer (see .specify/specs/vault-page-experience/spec.md)
model CompostLedger {
  id             String   @id @default(cuid())
  playerId       String
  createdAt      DateTime @default(now())
  /// JSON array of CustomBar ids composted in this session
  sourceIdsJson  String   @map("source_ids") @db.Text
  /// JSON: VaultSalvagePayload (salvageLines, tags, releaseNote)
  salvagePayload String   @map("salvage_payload") @db.Text
  outcome        String   @default("composted") // composted
  player         Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId, createdAt])
  @@map("compost_ledgers")
}

model Role {
  id                    String       @id @default(cuid())
  key                   String       @unique
  displayName           String
  description           String
  isForecasted          Boolean      @default(false)
  // Holacracy governance
  purpose               String? // what this role pursues or expresses
  accountabilities      String? // JSON array: ongoing activities the role enacts
  scope                 String       @default("instance") // instance | nation | global
  // NPC defaults — face/tier that fills this role when no human holds it
  npcFace               String? // shaman | challenger | regent | architect | diplomat | sage
  npcTier               Int          @default(1)
  // Prerequisite gate: JSON { minBars?, requiredRoleKeys?, alignmentThresholds? }
  prerequisites         String?
  // Quest spawned when role is granted to a human player
  orientationTemplateId String?
  createdAt             DateTime     @default(now())
  players               PlayerRole[]
  orientationTemplate   CustomBar?   @relation("RoleOrientationTemplate", fields: [orientationTemplateId], references: [id], onDelete: SetNull)

  @@map("roles")
}

model Account {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  players      Player[]

  @@map("accounts")
}

model PlayerRole {
  id               String     @id @default(cuid())
  playerId         String
  roleId           String
  grantedByAdminId String?
  grantedAt        DateTime   @default(now())
  expiresAt        DateTime?
  // Governance scope
  instanceId       String? // role is scoped to this campaign instance
  nationId         String? // role is scoped to this nation
  focus            String? // Holacracy: specific area/context within the role
  grantedByBarId   String? // the grantRole face move BAR that created this
  isFilledByNpc    Boolean    @default(false) // NPC is holding this role (no human yet)
  player           Player     @relation(fields: [playerId], references: [id])
  role             Role       @relation(fields: [roleId], references: [id])
  grantedByBar     CustomBar? @relation("PlayerRoleGrantBar", fields: [grantedByBarId], references: [id], onDelete: SetNull)

  @@unique([playerId, roleId])
  @@map("player_roles")
}

model Bar {
  id         Int         @id
  name       String
  tone       String
  text       String
  createdAt  DateTime    @default(now())
  assignedTo PlayerBar[]

  @@map("bars")
}

model CustomBar {
  id                                   String                 @id @default(cuid())
  creatorId                            String
  title                                String
  description                          String
  type                                 String                 @default("vibe")
  reward                               Int                    @default(1)
  visibility                           String                 @default("public")
  claimedById                          String?
  storyPath                            String?
  allowedTrigrams                      String?
  inputs                               String                 @default("[]")
  moveType                             String?
  status                               String                 @default("active") // seed | draft | active | archived — seed = emitted from spoke CYOA, needs tending
  archivedAt                           DateTime? // BAR UI Overhaul: soft archive (recoverable)
  mergedIntoId                         String? // when set, this BAR was merged into another
  mergedFromIds                        String? // JSON array of source BAR ids (when this is the merged result)
  collapsedFromQuestId                 String? // Share-as-BAR: when set, this BAR was collapsed from this quest
  collapsedFromInstanceId              String? // Share-as-BAR: when set, this BAR was collapsed from this campaign/instance
  kotterStage                          Int                    @default(1)
  storyContent                         String?
  storyMood                            String?
  isSystem                             Boolean                @default(false)
  hexagramId                           Int?
  periodGenerated                      Int?
  firstCompleterId                     String?
  maxAssignments                       Int                    @default(1)
  createdAt                            DateTime               @default(now())
  parentId                             String?
  twineLogic                           String?
  completionEffects                    String?
  rootId                               String?
  allowedNations                       String?
  allyshipDomain                       String? // GATHERING_RESOURCES | DIRECT_ACTION | RAISE_AWARENESS | SKILLFUL_ORGANIZING
  nation                               String? // thematic nation (Argyra, Pyrakanth, etc.) from book analysis
  archetype                            String? // thematic archetype (Bold Heart, Danger Walker, etc.) from book analysis
  lockType                             String? // identity_lock | emotional_lock | action | possibility (transformation alignment)
  campaignRef                          String? // e.g. bruised-banana; when set, quest is campaign-linked
  /// EIP: Partiful RSVP URL for event_invite BARs (external HTTPS).
  partifulUrl                          String?
  /// EIP: explicit slug for `/campaign/event/[eventSlug]/initiation` (e.g. apr-4-dance).
  eventSlug                            String?
  campaignGoal                         String? // e.g. throw a party; the goal this quest fulfills
  successCondition                     String? // Golden path: explicit success criterion (e.g. "Email sent")
  emotionalAlchemyTag                  String? // aligned | curious | skeptical; when set, quest preferred for that onboarding branch
  forkedFromId                         String? // when set, this quest is a private fork of another
  gameMasterFace                       String? // shaman | challenger | regent | architect | diplomat | sage (dojo alignment for growUp)
  twineStoryId                         String?
  docQuestMetadata                     String? // JSON: { docIntent, targetDocNodeId, targetLibraryRequestId, schismId, validationChecklist, barRequirements }
  backlogPromptPath                    String? // e.g. .specify/specs/lore-cyoa-onboarding/spec.md (verification quest → backlog update)
  evidenceKind                         String? // observation | instruction | canon_statement | spec_clause | lore | schism (when CustomBar is evidence)
  sourceBarId                          String? // when set, this quest was generated from this BAR (BAR → Quest Generation Engine)
  source321SessionId                   String? // when set, this quest was created from 321 session (Singleplayer Charge Metabolism)
  cmaGeneratorDrafts                   CmaGeneratorDraft[]
  proposedByAgentId                    String? // when set, this BAR/quest was proposed by an agent (NPC); requires admin approval before publication
  // Provenance Stamp fields (PSS) — set at creation, immutable; persists through trades
  creatorNationKey                     String?                @map("creator_nation_key") // nationKey of the creating player
  creatorArchetypeKey                  String?                @map("creator_archetype_key") // archetypeKey of the creating player
  isKeyUnblocker                       Boolean                @default(false) // tetris: completing this subquest unblocks root + siblings
  grantsMoveId                         String? // when set, completing this quest unlocks this NationMove
  questSource                          String? // system | bounty; bounties have stakedPool > 0
  stakedPool                           Int                    @default(0) // vibeulons in escrow for bounty payouts
  agentMetadata                        String? // JSON: { agent, deterministic, confidence, reasoning, discernedMove, usageTokens }
  strandMetadata                       String? // JSON: { agent_sequence, phase_temperature, output_thread_links, audit_trail, branch_reference, thread_linkage? } when type=strand
  questPool                            String? // efa | dojo | discovery | gameboard — wave routing for book-derived quests
  /// Playbook slug at charge capture (IE-10); immutable once set; null = no archetype stamp
  archetypeKey                         String?
  inviteId                             String? // when set, this BAR is an invitation BAR linked to that invite
  wateringProgress                     String? // JSON: { shaman, regent, challenger, architect, diplomat, sage } — campaign kernel watering
  wateringContent                      String? // JSON: { shaman: string, regent: string, ... } — stored responses per face
  intensity                            String? // everyday | capable | skilled | defining — move intensity register (Hearts Blazing-derived)
  contextLines                         String? // JSON: { solo: string, interpersonal: string, narrative: string } — I/We/Its expressions for group play
  /// BSM (BAR Seed Metabolization): JSON { soilKind?, contextNote?, maturity?, compostedAt?, releaseNote? }
  seedMetabolization                   String?
  isExemplar                           Boolean                @default(false) // marked by GM faces for cultural substrate distillation pipeline
  spokeSessionId                       String? // FK → SpokeSession; set when BAR seed was emitted from a spoke CYOA (status=seed)
  /// CSHE: clothing-swap listing excluded from public gallery (host/co-host moderation)
  swapListingHidden                    Boolean                @default(false) @map("swap_listing_hidden")
  invite                               Invite?                @relation("InvitationBar", fields: [inviteId], references: [id], onDelete: SetNull)
  promotedInstance                     Instance?              @relation("CampaignKernel") // Instance.kernelBarId points here when promoted
  invitesAsStarterQuest                Invite[]               @relation("InviteStarterQuest")
  invitesAsInvitationBar               Invite[]               @relation("InviteInvitationBar")
  shares                               BarShare[]
  shareExternals                       BarShareExternal[]
  socialLinks                          BarSocialLink[]
  bountyStakes                         BountyStake[]
  claimedBy                            Player?                @relation("ClaimedBars", fields: [claimedById], references: [id])
  creator                              Player                 @relation("CreatedBars", fields: [creatorId], references: [id])
  parent                               CustomBar?             @relation("CustomBarTree", fields: [parentId], references: [id])
  children                             CustomBar[]            @relation("CustomBarTree")
  forkedFrom                           CustomBar?             @relation("QuestFork", fields: [forkedFromId], references: [id], onDelete: SetNull)
  forks                                CustomBar[]            @relation("QuestFork")
  twineStory                           TwineStory?            @relation(fields: [twineStoryId], references: [id])
  packQuests                           PackQuest[]
  assignments                          PlayerQuest[]
  moveLogsAsCreatedBar                 QuestMoveLog[]         @relation("QuestMoveCreatedBar")
  questMoveLogs                        QuestMoveLog[]         @relation("QuestMoveQuest")
  threadQuests                         ThreadQuest[]
  linkedPassages                       Passage[]              @relation("PassageLinkedQuest")
  upgradedThreads                      QuestThread[]          @relation("QuestUpgradeProvenance")
  microTwine                           MicroTwineModule?
  libraryRequestsSpawned               LibraryRequest[]       @relation("LibraryRequestSpawnedQuest")
  gameboardSlots                       GameboardSlot[]
  aidOffersLinked                      GameboardAidOffer[]    @relation("AidOfferLinkedQuest")
  questAdventureLinks                  QuestAdventureLink[]   @relation("QuestAdventureLinks")
  sourceBar                            CustomBar?             @relation("BarConversion", fields: [sourceBarId], references: [id], onDelete: SetNull)
  questsFromBar                        CustomBar[]            @relation("BarConversion")
  questProposals                       QuestProposal[]
  responses                            BarResponse[]
  bindings                             BarBinding[]
  assets                               Asset[]
  nextActionBridgesAsQuest             NextActionBridge[]     @relation("NextActionBridgeQuest")
  nextActionBridgesAsBar               NextActionBridge[]     @relation("NextActionBridgeBar")
  topicAssignments                     BarTopicAssignment[]
  collapsedFromQuest                   CustomBar?             @relation("BarCollapsedFromQuest", fields: [collapsedFromQuestId], references: [id], onDelete: SetNull)
  collapsedFromInstance                Instance?              @relation("BarCollapsedFromInstance", fields: [collapsedFromInstanceId], references: [id], onDelete: SetNull)
  barsCollapsedFromQuest               CustomBar[]            @relation("BarCollapsedFromQuest")
  campaignInvitation                   CampaignInvitation? // one BAR can carry one role invitation
  carriedWeightResults                 CarriedWeight[]        @relation("CarriedWeightBar")
  roleOrientations                     Role[]                 @relation("RoleOrientationTemplate")
  playerRoleGrants                     PlayerRole[]           @relation("PlayerRoleGrantBar")
  spokeSession                         SpokeSession?          @relation("SpokeBarSeeds", fields: [spokeSessionId], references: [id], onDelete: SetNull)
  marketplaceStallListing              MarketplaceStallSlot?  @relation("MarketplaceListedBar")
  friendshipInvitationsAsInvitationBar FriendshipInvitation[]
  /// ECI: allyship interview submissions from event_invite CYOA (emergent campaign intake).
  latentAllyshipIntakes                LatentAllyshipIntake[]
  /// SMB: canonical spoke-emitted BAR anchor for a move bed
  spokeMoveBedAnchor                   SpokeMoveBed?          @relation("SpokeMoveBedAnchor")
  spokeMoveBedKernelRows               SpokeMoveBedKernel[]   @relation("SpokeMoveBedKernelBar")
  spokeMoveBedKernelSources            SpokeMoveBedKernel[]   @relation("SpokeMoveBedKernelSource")
  barForgeRecordsAsPrimary             BarForgeRecord[]       @relation("BarForgePrimaryQuest")
  barMedia                             BarMedia[]
  daemonsGrownFromBar                  Daemon[]               @relation("DaemonSourceBar")

  @@index([collapsedFromInstanceId, type])
  @@map("custom_bars")
}

/// Attachments uploaded to a BAR (blob URL + metadata).
model BarMedia {
  id        String   @id @default(cuid())
  barId     String
  blobUrl   String
  kind      String // image | file
  name      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  bar CustomBar @relation(fields: [barId], references: [id], onDelete: Cascade)

  @@index([barId])
  @@map("bar_media")
}

/// BAR Forge / Custom GPT: persisted BAR analyses + quest links (no Player ownership required).
model BarForgeRecord {
  id                String   @id @default(cuid())
  bar               String   @db.Text
  analysisType      String
  wavePhase         String
  polarity          Json
  primaryQuestId    String?
  secondaryQuestIds Json
  source            String?
  metadataJson      Json?
  createdAt         DateTime @default(now())

  primaryQuest CustomBar? @relation("BarForgePrimaryQuest", fields: [primaryQuestId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@map("bar_forge_records")
}

/// Emergent campaign from BAR interview (ECI) — structured path through invite CYOA before child campaign exists.
model LatentAllyshipIntake {
  id                String    @id @default(cuid())
  customBarId       String
  /// Logged-in submitter when available.
  playerId          String?
  /// Browser-stable id (localStorage) for anonymous correlation / dedupe hints.
  clientSessionId   String?
  /// `EventInviteStory.id` at submit time (template versioning).
  storyId           String
  /// Last passage id (usually ending).
  endingPassageId   String
  /// JSON: { steps: { passageId, choiceLabel, nextPassageId }[] }
  pathJson          String    @db.Text
  /// Denormalized from invite URL ?note= for steward context.
  senderNote        String?   @db.Text
  status            String    @default("submitted") // submitted | watered (ECI-B)
  /// When set, this intake was watered into a child campaign instance.
  spawnedInstanceId String?   @map("spawned_instance_id")
  wateredAt         DateTime? @map("watered_at")
  wateredByPlayerId String?   @map("watered_by_player_id")
  stewardNotes      String?   @map("steward_notes") @db.Text
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  customBar       CustomBar @relation(fields: [customBarId], references: [id], onDelete: Cascade)
  player          Player?   @relation(fields: [playerId], references: [id], onDelete: SetNull)
  spawnedInstance Instance? @relation("AllyshipIntakeSpawnedInstance", fields: [spawnedInstanceId], references: [id], onDelete: SetNull)
  wateredBy       Player?   @relation("AllyshipIntakeWateredBy", fields: [wateredByPlayerId], references: [id], onDelete: SetNull)

  @@index([customBarId, createdAt])
  @@index([playerId])
  @@index([customBarId, clientSessionId])
  @@index([spawnedInstanceId])
  @@map("latent_allyship_intakes")
}

model NextActionBridge {
  id         String   @id @default(cuid())
  questId    String
  barId      String? // Optional: when from cleanup BAR
  nextAction String   @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

