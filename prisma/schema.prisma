model EventArtifact {
  id                    String               @id @default(cuid())
  linkedCampaignId      String
  parentEventArtifactId String?              @map("parent_event_artifact_id")
  instanceId            String?              @map("instance_id")
  title                 String
  description           String
  eventType             String
  topic                 String
  campaignContext       String
  primaryDomain         String
  secondaryDomain       String?
  targetArchetypes      String               @default("[]")
  targetMoves           String               @default("[]")
  developmentalLens     String?
  locationType          String
  locationDetails       String?
  startTime             DateTime?
  endTime               DateTime?
  timezone              String?
  capacity              Int?
  recurrenceRule        String?              @map("recurrence_rule")
  visibility            String               @default("campaign_visible")
  status                String               @default("draft")
  recordingUrl          String?
