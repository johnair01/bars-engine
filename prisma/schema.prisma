  startedAt    DateTime         @default(now())
  endedAt      DateTime?
  createdAt    DateTime         @default(now())
  instance     Instance?        @relation("CampaignPeriods", fields: [instanceId], references: [id])
  portals      CampaignPortal[]

  @@unique([campaignRef, periodNumber])
  @@index([campaignRef, status])
  @@map("campaign_periods")
}

/// A physical portal entry on the campaign hub page.
/// Created (8 per period) when an admin calls drawPeriod.
model CampaignPortal {
  id              String            @id @default(cuid())
  periodId        String
  campaignRef     String
  slotIndex       Int
  hexagramId      Int?
  deckCardId      String?
  cyoaAdventureId String?
