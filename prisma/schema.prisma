  equipSlots    PlayerMoveEquip[]
  uses          MoveUse[]
  childMoves    NationMove[]             @relation("NationMoveParent")
  parentMove    NationMove?              @relation("NationMoveParent", fields: [parentMoveId], references: [id], onDelete: SetNull)
