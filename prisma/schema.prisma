  createdAt   DateTime   @default(now())
  createdBy   Player     @relation("TwineBindingsCreated", fields: [createdById], references: [id], onDelete: Cascade)
  story       TwineStory @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@index([storyId, scopeType, scopeId])
  @@map("twine_bindings")
}

model Instance {
  id                    String                  @id @default(cuid())
  slug                  String                  @unique
  name                  String
  domainType            String
  theme                 String?
  targetDescription     String?
  wakeUpContent         String? // Editable "Learn the story" paragraph
  showUpContent         String? // Editable "Contribute to the campaign" paragraph
  storyBridgeCopy       String? // Optional: game↔real world bridge ("This residency is your Conclave...")
  campaignRef           String? // Default campaign when /campaign has no ref (e.g. bruised-banana)
  primaryCampaignDomain String? // Top-level campaign's allyship domain (e.g. GATHERING_RESOURCES for bruised-banana)
  narrativeKernel       String? // Campaign kernel: shared narrative premise used for AI generation
  goalAmountCents       Int?
  currentAmountCents    Int                     @default(0)
  kotterStage           Int                     @default(1) // 1–8; admin advances
  timezone              String? // IANA timezone (e.g. America/Los_Angeles) for "start of day" in charge capture; null = UTC
  allyshipDomain        String? // GATHERING_RESOURCES | DIRECT_ACTION | RAISE_AWARENESS | SKILLFUL_ORGANIZING; when set, gameboard uses domain deck
  domainDeckCycles      Json                    @default("{}") // { [domain]: { playedQuestIds: string[], cycleId: string } }
  isEventMode           Boolean                 @default(false)
  stripeOneTimeUrl      String?
  patreonUrl            String?
  venmoUrl              String?
  cashappUrl            String?
  paypalUrl             String?
  donationPackRateCents Int?                    @default(100) // 100 = 1 pack per $1
  packConfig            String? // JSON: { packTypes: { [key]: { vibeulonAmount?: number, vibeulonMin?: number, vibeulonMax?: number } } }
  startDate             DateTime?
  endDate               DateTime?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  activeInConfigs       AppConfig[]
  donations             Donation[]
  memberships           InstanceMembership[]
  participations        InstanceParticipation[]
  redemptionPacks       RedemptionPack[]
  libraryRequests       LibraryRequest[]

  vibeData         String? // JSON: vibe interview answers
  goalData         String? // JSON: campaign goal interview answers
  sourceInstanceId String? // if copied from another instance
  parentInstanceId String? @map("parent_instance_id") // when set, this instance is a sub-campaign of the parent
  linkedInstanceId String? @map("linked_instance_id") // when set, this instance links to another (e.g. Fundraising → Bruised Banana)
  kernelBarId      String? @unique // when set, this Instance was promoted from this campaign_kernel BAR
  moveIds          String  @default("[]") // JSON array of NationMove ids — campaign move pool (Sage synthesis)

  parentInstance             Instance?               @relation("InstanceChildren", fields: [parentInstanceId], references: [id], onDelete: SetNull)
  childInstances             Instance[]              @relation("InstanceChildren")
  linkedInstance             Instance?               @relation("InstanceLinkedTo", fields: [linkedInstanceId], references: [id], onDelete: SetNull)
  instancesLinkedToMe        Instance[]              @relation("InstanceLinkedTo")
  kernelBar                  CustomBar?              @relation("CampaignKernel", fields: [kernelBarId], references: [id], onDelete: SetNull)
  gameboardSlots             GameboardSlot[]
  eventCampaigns             EventCampaign[]
  eventArtifacts             EventArtifact[]
  campaignPlaybook           CampaignPlaybook?
  campaignInvitations        CampaignInvitation[]
  deckLibrary                DeckLibrary? // Container for multiple BarDecks (scene-atlas + friendship decks)
  scopedNations              Nation[]                @relation("NationInstance")
  scopedArchetypes           Archetype[]             @relation("ArchetypeInstance")
  exportRequests             InstanceExportRequest[]
  spatialMapId               String?                 @map("spatial_map_id")
  spatialMap                 SpatialMap?             @relation("InstanceSpatialMap", fields: [spatialMapId], references: [id], onDelete: SetNull)
  portalAdventureId          String? // FK to Adventure: 8 portal entries + 8 room passages per campaign
  portalAdventure            Adventure?              @relation("InstancePortalAdventure", fields: [portalAdventureId], references: [id], onDelete: SetNull)
  /// v1 JSON: { v, kotterStage, spokes: [{ hexagramId, changingLines, primaryFace }], updatedAt } — one draw per Kotter stage (campaign hub)
  campaignHubState           Json?
  /// WMC admin Deck CYOA wizard — last applied intake JSON (DeckIntakeV1) for reproducible deck generation
  deckAuthoringIntake        Json?
  schoolsAdventureId         String? // FK to Adventure: 6-face schools CYOA (Grow Up from room)
  schoolsAdventure           Adventure?              @relation("InstanceSchoolsAdventure", fields: [schoolsAdventureId], references: [id], onDelete: SetNull)
  invites                    Invite[]
  demoOrientationLinks       DemoOrientationLink[]
  barsCollapsedFromInstance  CustomBar[]             @relation("BarCollapsedFromInstance")
  barShareExternals          BarShareExternal[]
  questThreads               QuestThread[]
  campaignPeriods            CampaignPeriod[]        @relation("CampaignPeriods")
  /// CSHE / clothing-swap sub-campaign: organizer intake JSON (SwapEventIntakeV1); null = not using swap-event intake on this instance
  swapEventIntake            Json?                   @map("swap_event_intake")
  /// When set, participants may read published intake (organizers always see latest draft in organizer UI)
  swapEventIntakePublishedAt DateTime?               @map("swap_event_intake_published_at")
  swapEventRsvps             SwapEventRsvp[]
  friendshipInvitations      FriendshipInvitation[]

  @@map("instances")
}

/// CSHE Phase B — light RSVP without full onboarding (Partiful remains canonical).
model SwapEventRsvp {
  id                      String   @id @default(cuid())
  instanceId              String   @map("instance_id")
  email                   String
  name                    String?
  partifulRef             String?  @map("partiful_ref")
  externalRef             String?  @map("external_ref")
  /// Audit: guest opted into RSVP-only path (no nation/archetype required).
  skipFullOnboarding      Boolean  @default(true) @map("skip_full_onboarding")
  createdAt               DateTime @default(now()) @map("created_at")

  instance Instance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@index([instanceId, createdAt])
  @@map("swap_event_rsvps")
}

model InstanceExportRequest {
  id                  String    @id @default(cuid())
  instanceId          String
  requestedByPlayerId String
  status              String    @default("pending") // pending | approved | rejected
  configBundle        String? // JSON config export (set on approval)
  requestedAt         DateTime  @default(now())
  resolvedAt          DateTime?

  instance Instance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  player   Player   @relation(fields: [requestedByPlayerId], references: [id], onDelete: Cascade)

  @@index([instanceId, status])
  @@map("instance_export_requests")
}

/// Deck type enumeration for BarDeck variants
enum DeckType {
  SCENE_ATLAS
  FRIENDSHIP_52
  FRIENDSHIP_64
}

/// DeckLibrary: Container enabling one Instance to have multiple BarDecks of different types
model DeckLibrary {
  id         String   @id @default(cuid())
  instanceId String   @unique // One library per Instance
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  instance Instance  @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  decks    BarDeck[]

  @@index([instanceId])
  @@map("deck_libraries")
}

model BarDeck {
  id        String   @id @default(cuid())
  libraryId String   // References DeckLibrary instead of Instance directly
  deckType  DeckType // Differentiator: scene-atlas, friendship-52, friendship-64
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  library          DeckLibrary       @relation(fields: [libraryId], references: [id], onDelete: Cascade)
  cards            BarDeckCard[]
  promptDeckCycles PromptDeckCycle[]

  @@unique([libraryId, deckType]) // One of each type per library
  @@index([libraryId])
  @@map("bar_decks")
}

model BarDeckCard {
  id           String   @id @default(cuid())
  deckId       String
  suit         String // GATHERING_RESOURCES | RAISE_AWARENESS | DIRECT_ACTION | SKILLFUL_ORGANIZING
  rank         Int // 1-13
  promptTitle  String
  promptText   String   @db.Text
  shufflePower Boolean  @default(false)
  metadata     Json     @default("{}")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  deck                  BarDeck                 @relation(fields: [deckId], references: [id], onDelete: Cascade)
  bindings              BarBinding[]
  guidedDrafts          SceneAtlasGuidedDraft[]
  friendshipInvitations FriendshipInvitation[]

  @@unique([deckId, suit, rank])
  @@index([deckId])
  @@map("bar_deck_cards")
}

model BarBinding {
  id            String   @id @default(cuid())
  cardId        String
  barId         String
  authorActorId String
  instanceId    String?
  status        String   @default("active") // active | removed | archived
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  card BarDeckCard @relation(fields: [cardId], references: [id], onDelete: Cascade)
  bar  CustomBar   @relation(fields: [barId], references: [id], onDelete: Cascade)

  @@index([cardId])
  @@index([barId])
  @@map("bar_bindings")
}

/// P2 Scene Atlas: persisted CYOA-style guided answers per player × deck card (resume across sessions).
model SceneAtlasGuidedDraft {
  id         String   @id @default(cuid())
  playerId   String
  cardId     String
  instanceId String
  payload    Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  player Player      @relation(fields: [playerId], references: [id], onDelete: Cascade)
  card   BarDeckCard @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([playerId, cardId])
  @@index([playerId, instanceId])
  @@map("scene_atlas_guided_drafts")
}

/// Prompt deck play cycle (draw / discard) per player × BarDeck — orthogonal to BarBinding / grid.
/// Global hand: `PlayerPromptHand.handCardIds` (max 5 across all decks). See prompt-deck-draw-hand spec.
model PlayerPromptHand {
  id          String   @id @default(cuid())
  playerId    String   @unique
  handCardIds String   @default("[]") @db.Text // JSON: BarDeckCard ids, max 5
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@map("player_prompt_hands")
}

model PromptDeckCycle {
  id             String   @id @default(cuid())
  playerId       String
  deckId         String
  drawCardIds    String   @default("[]") @db.Text // JSON array
  discardCardIds String   @default("[]") @db.Text // JSON array
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  player Player  @relation(fields: [playerId], references: [id], onDelete: Cascade)
  deck   BarDeck @relation(fields: [deckId], references: [id], onDelete: Cascade)

  @@unique([playerId, deckId])
  @@index([playerId])
  @@map("prompt_deck_cycles")
}

model ActorDeckState {
  id             String    @id @default(cuid())
  actorId        String
  instanceId     String
  deckCardIds    String    @default("[]") // JSON array: cards remaining in deck
  handCardIds    String    @default("[]") // JSON array: 7 cards in hand
  discardCardIds String    @default("[]") // JSON array: played cards
  lastDrawAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([actorId, instanceId])
  @@index([actorId])
  @@index([instanceId])
  @@map("actor_deck_states")
}

model CampaignInvitation {
  id               String    @id @default(cuid())
  instanceId       String
  targetActorId    String
  invitedRole      String
  acceptedRole     String?
  invitationType   String // guiding_coalition | campaign_collaborator | domain_contributor | event_participant | observer | role_invitation
  messageText      String    @db.Text
  status           String    @default("draft") // draft | sent | accepted | declined | expired
  createdByActorId String
  sentAt           DateTime?
  respondedAt      DateTime?
  barId            String?   @unique // when set, this invitation is delivered via this BAR
  eventArtifactId  String?   @map("event_artifact_id") // when invitationType=event_participant, links to specific event
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  instance      Instance       @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  bar           CustomBar?     @relation(fields: [barId], references: [id], onDelete: SetNull)
  eventArtifact EventArtifact? @relation(fields: [eventArtifactId], references: [id], onDelete: SetNull)

  @@index([instanceId])
  @@index([targetActorId])
  @@index([status])
  @@index([barId])
  @@map("campaign_invitations")
}

model CampaignPlaybook {
  id               String   @id @default(cuid())
  instanceId       String   @unique
  origin           String   @default("")
  vision           String   @default("")
  people           String   @default("")
  invitations      String   @default("")
  timeline         String   @default("")
  kotterStages     Json     @default("{}") // { "1": "...", "2": "...", ... }
  domainStrategy   Json     @default("{}") // { "GATHERING_RESOURCES": "...", ... }
  raciRoles        String   @default("")
  recentUpdates    String   @default("")
  generatedSummary String   @default("")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  instance Instance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@map("campaign_playbooks")
}

model EventCampaign {
  id                String   @id @default(cuid())
  campaignContext   String // e.g. Bruised Banana Residency
  topic             String // e.g. Emotional First Aid, Friendcraft
  primaryDomain     String // GATHERING_RESOURCES | SKILLFUL_ORGANIZING | RAISE_AWARENESS | DIRECT_ACTION
  productionGrammar String // kotter | epiphany_bridge
  campaignType      String   @default("event_production")
  hostActorIds      String   @default("[]") // JSON array of Player ids
  targetArchetypes  String   @default("[]") // JSON array
  targetMoves       String   @default("[]") // JSON array: wakeUp, cleanUp, growUp, showUp
  developmentalLens String?
  status            String   @default("proposed") // proposed | planning | assembling | promotion | ready | event_live | post_event | archived
  linkedEventIds    String   @default("[]") // JSON array of EventArtifact ids
  instanceId        String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  instance         Instance?       @relation(fields: [instanceId], references: [id], onDelete: SetNull)
  productionThread QuestThread?
  events           EventArtifact[]

  @@index([instanceId])
  @@index([status])
  @@map("event_campaigns")
}

model EventArtifact {
  id                    String    @id @default(cuid())
  linkedCampaignId      String
  // When set: sub-event (e.g. pre-production crew) under the parent main event.
  parentEventArtifactId String?   @map("parent_event_artifact_id")
  instanceId            String?   @map("instance_id") // when set, this artifact is the "live event" for that Instance
  title                 String
  description           String    @db.Text
  eventType             String // workshop | meeting | fundraiser | dance | onboarding_session | discussion | training | ceremony | quest_action | gathering
  topic                 String // inherited from campaign
  campaignContext       String // inherited from campaign
  primaryDomain         String // inherited from campaign
  secondaryDomain       String? // operational function of this event
  targetArchetypes      String    @default("[]") // JSON array
  targetMoves           String    @default("[]") // JSON array
  developmentalLens     String?
  locationType          String // in_person | virtual | hybrid | asynchronous_recording
  locationDetails       String?
  startTime             DateTime?
  endTime               DateTime?
  timezone              String?
  capacity              Int? // max attendees; null = unlimited
  recurrenceRule        String?   @map("recurrence_rule") // optional RRULE (Phase 6+); not wired in UI yet
  visibility            String    @default("campaign_visible") // private | campaign_visible | public
  status                String    @default("draft") // draft | scheduled | live | completed | recorded | archived
  recordingUrl          String?
  createdByActorId      String
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  campaign            EventCampaign        @relation(fields: [linkedCampaignId], references: [id], onDelete: Cascade)
  parentEvent         EventArtifact?       @relation("EventArtifactNested", fields: [parentEventArtifactId], references: [id], onDelete: SetNull)
  childEvents         EventArtifact[]      @relation("EventArtifactNested")
  instance            Instance?            @relation(fields: [instanceId], references: [id], onDelete: SetNull)
  creator             Player               @relation("EventArtifactCreator", fields: [createdByActorId], references: [id])
  invites             EventInvite[]
  participants        EventParticipant[]
  campaignInvitations CampaignInvitation[]

  @@index([linkedCampaignId])
  @@index([instanceId])
  @@index([parentEventArtifactId])
  @@index([status])
  @@index([startTime])
  @@map("event_artifacts")
}

model EventParticipant {
  id               String   @id @default(cuid())
  eventId          String
  participantId    String
  participantState String // invited | interested | RSVP_yes | attending | attended | declined | no_show
  functionalRole   String? // host | co_host | facilitator | steward | participant | observer | preproduction
  raciRole         String? // Responsible | Accountable | Consulted | Informed
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  event       EventArtifact @relation(fields: [eventId], references: [id], onDelete: Cascade)
  participant Player        @relation("EventParticipantAsParticipant", fields: [participantId], references: [id], onDelete: Cascade)

  @@unique([eventId, participantId])
  @@index([participantId])
  @@map("event_participants")
}

model EventInvite {
  id               String   @id @default(cuid())
  eventId          String
  actorId          String
  invitedByActorId String
  inviteStatus     String   @default("pending") // pending | accepted | declined | expired
  inviteSource     String? // campaign_broadcast | direct_actor | quest_bar | public_discovery | organizer_admin
  createdAt        DateTime @default(now())

  event     EventArtifact @relation(fields: [eventId], references: [id], onDelete: Cascade)
  actor     Player        @relation("EventInviteReceived", fields: [actorId], references: [id], onDelete: Cascade)
  invitedBy Player        @relation("EventInviteSent", fields: [invitedByActorId], references: [id], onDelete: Cascade)

  @@unique([eventId, actorId])
  @@index([actorId])
  @@map("event_invites")
}

model GameboardSlot {
  id                String    @id @default(cuid())
  instanceId        String
  campaignRef       String
  period            Int // instance.kotterStage or GlobalState.currentPeriod
  slotIndex         Int // 0–7 (8 slots, one per hexagram in period)
  hexagramId        Int? // 1–64; each period uses 8 hexagrams, slot tied to one
  moveType          String? // wakeUp | cleanUp | growUp | showUp; set when player commits to path from portal
  questId           String?
  drawnAt           DateTime?
  stewardId         String? // player who has taken but not completed
  wakeUpAt          DateTime? // step 1: acknowledged read
  cleanUpAt         DateTime? // step 2: reflected on obstacles
  cleanUpReflection String? // step 2: obstacle reflection text
  createdAt         DateTime  @default(now())

  instance  Instance            @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  quest     CustomBar?          @relation(fields: [questId], references: [id], onDelete: SetNull)
  steward   Player?             @relation("GameboardSteward", fields: [stewardId], references: [id], onDelete: SetNull)
  bids      GameboardBid[]
  aidOffers GameboardAidOffer[]

  @@unique([instanceId, campaignRef, period, slotIndex])
  @@index([instanceId, campaignRef, period, moveType])
  @@index([instanceId, campaignRef, period])
  @@map("gameboard_slots")
}

model GameboardBid {
  id        String   @id @default(cuid())
  slotId    String
  bidderId  String
  amount    Int // vibeulons (each Vibulon token = 1)
  status    String   @default("active") // active | won | withdrawn
  createdAt DateTime @default(now())

  slot   GameboardSlot @relation(fields: [slotId], references: [id], onDelete: Cascade)
  bidder Player        @relation(fields: [bidderId], references: [id], onDelete: Cascade)

  @@index([slotId, status])
  @@index([bidderId])
  @@map("gameboard_bids")
}

model GameboardAidOffer {
  id            String    @id @default(cuid())
  slotId        String
  stewardId     String
  offererId     String
  message       String    @db.Text
  type          String    @default("direct") // direct (EFA, support) | quest (quest to unblock)
  linkedQuestId String? // for type=quest: quest created to help steward
  status        String    @default("pending") // pending | accepted | declined
  expiresAt     DateTime? // steward must respond by this time; configurable TTL from createdAt
  forkedAt      DateTime? // when offerer forked the linked quest after decline
  createdAt     DateTime  @default(now())

  slot        GameboardSlot @relation(fields: [slotId], references: [id], onDelete: Cascade)
  steward     Player        @relation("GameboardAidSteward", fields: [stewardId], references: [id], onDelete: Cascade)
  offerer     Player        @relation("GameboardAidOfferer", fields: [offererId], references: [id], onDelete: Cascade)
  linkedQuest CustomBar?    @relation("AidOfferLinkedQuest", fields: [linkedQuestId], references: [id], onDelete: SetNull)

  @@index([slotId])
  @@index([stewardId, status])
  @@map("gameboard_aid_offers")
}

/// Player-owned campaign marketplace profile (mall stalls) per campaignRef — separate from instance gameboard deck draws.
model PlayerMarketplaceProfile {
  id               String   @id @default(cuid())
  playerId         String
  campaignRef      String
  /// 8 base + paidExtensions
  maxSlots         Int      @default(8)
  paidExtensions   Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  player           Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  stallSlots       MarketplaceStallSlot[]

  @@unique([playerId, campaignRef])
  @@index([campaignRef])
  @@map("player_marketplace_profiles")
}

/// One numbered stall in a player marketplace profile; lists a CustomBar (BAR or quest).
model MarketplaceStallSlot {
  id                String                   @id @default(cuid())
  profileId         String
  slotIndex         Int
  listedCustomBarId String?                  @unique
  createdAt         DateTime                 @default(now())
