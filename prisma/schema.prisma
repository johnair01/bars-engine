/// GM annotation: marks an existing tracked action as a meaningful campaign contribution
/// and provides a GM-written label for player-facing display.
/// Soft-archive via status='retired' preserves historical player records.
model ContributionAnnotation {
  id          String   @id @default(cuid())
  campaignRef String
  /// Type of tracked action: quest | bar | milestone | adventure
  actionType  String
  /// FK to the specific action (CustomBar.id, CampaignMilestone.id, Adventure.id, etc.)
  actionId    String
  /// GM-authored label shown to players in their contribution list
  gmLabel     String
  /// active | retired — soft archive; retired keeps historical records but blocks new completions
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String
  createdBy   Player   @relation("ContributionAnnotationCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)

  @@unique([campaignRef, actionType, actionId])
  @@index([campaignRef, status])
  @@map("contribution_annotations")
}

/// Sub-campaign slot: organizes campaign content into a navigable hierarchy.
/// Max nesting: campaign → branch (level 1) → sub-branch (level 2) → adventure container (level 3).
model CampaignSlot {
  id           String         @id @default(cuid())
  campaignRef  String
  /// Null for top-level branches; set for nested slots
  parentSlotId String?
  /// Nesting depth: 1=branch, 2=sub-branch, 3=adventure container
  level        Int            @default(1)
  title        String
  description  String?
  /// JSON array of Adventure IDs linked to this slot
  adventureIds String         @default("[]")
  /// active | archived — soft archive
  status       String         @default("active")
  sortOrder    Int            @default(0)
  createdById  String
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  createdBy    Player         @relation("CampaignSlotCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  parentSlot   CampaignSlot?  @relation("CampaignSlotChildren", fields: [parentSlotId], references: [id])
  childSlots   CampaignSlot[] @relation("CampaignSlotChildren")

  @@index([campaignRef, parentSlotId])
  @@index([campaignRef, status])
  @@map("campaign_slots")
}

/// A player's completed action counted as a campaign contribution.
/// Records are created when a player completes a GM-annotated quest/BAR/milestone/adventure.
/// status='retired' is a soft archive — records are still counted in progress, but the
/// source action is no longer available to new players.
model ContributionRecord {
  id          String   @id @default(cuid())
  /// The campaign this contribution rolls up to (e.g. "bruised-banana")
  campaignRef String
  /// The player who earned this contribution
  playerId    String
  /// Type of tracked action: quest | bar | milestone | adventure
  sourceType  String
  /// ID of the completed quest / CustomBar / CampaignMilestone / Adventure
  sourceId    String
  /// GM-authored label (copied from ContributionAnnotation.gmLabel at record creation)
  gmLabel     String   @default("")
  /// active | retired — soft archive; retired records still count toward progress
  status      String   @default("active")
  earnedAt    DateTime @default(now())
  player      Player   @relation("PlayerContributions", fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([campaignRef, playerId, sourceType, sourceId])
  @@index([campaignRef, playerId])
  @@index([campaignRef, status])
  @@map("contribution_records")
}

/// GM-curated milestone marker with a narrative text block.
/// Generated by the conversational intake wizard; fully editable post-generation.
/// Triggers display of narrativeText when a player's contribution count reaches triggerCount.
model CampaignMilestoneMarker {
  id            String   @id @default(cuid())
  /// The campaign this milestone belongs to (e.g. "bruised-banana")
  campaignRef   String
  /// Display name (editable post-generation)
  name          String
  /// Number of contributions required to show this narrative to the player
  triggerCount  Int
  /// Generated narrative text (editable post-generation)
  narrativeText String
  /// active | retired — soft archive
  status        String   @default("active")
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([campaignRef, status])
  @@map("campaign_milestone_markers")
}

model Campaign {
  id                   String               @id @default(cuid())
  /// URL-safe slug (unique across all campaigns)
  slug                 String               @unique
  /// Human-readable campaign name
  name                 String
  /// Rich description shown on campaign landing
  description          String?
  /// Lifecycle: draft → pending_review → approved/rejected → live → archived
  status               CampaignStatus       @default(DRAFT)
  /// Phase 3: stewardship abandonment
  abandonmentFlagged   Boolean              @default(false) @map("abandonment_flagged")
  decompositionAt      DateTime?            @map("decomposition_at")
  /// Allyship domain focus (mirrors Instance.allyshipDomain)
  allyshipDomain       String?
  /// Wake Up copy (campaign story / "Learn the story")
  wakeUpContent        String?
  /// Show Up copy ("Contribute to the campaign")
  showUpContent        String?
  /// Story bridge copy (game↔real-world bridge)
  storyBridgeCopy      String?
  /// L1: Quest template configuration (Array of { templateType, overrides })
  questTemplateConfig  Json?
  /// L1: Invite configuration { method, capacity, messaging }
  inviteConfig         Json?
  /// L3: Reserved — narrative sovereignty runtime configuration.
  /// DO NOT populate until L3 implementation ships. Null = L3 not enabled for this campaign.
  /// Future purpose: holds campaign-specific CYOA graph config, bingo board definitions,
  /// NPC encounter parameters, and narrative-branching state machines.
  /// Expected shape (L3): {
  /// cyoa?: { graphId: string, entryNodeId: string, branchingRules: object },
  /// bingo?: { boardTemplate: string, prizeConfig: object },
  /// npc?: { constitutionIds: string[], encounterFrequency: string },
  /// branchingStateMachine?: object
  /// }
  /// Constraints: validated at application layer; must not exceed 64KB;
  /// references (graphId, constitutionIds) must resolve to existing entities.
  narrativeConfig      Json?
  /// L3: Narrative sovereignty permissions — who controls what narrative elements at runtime.
  /// DO NOT populate until L3 implementation ships. Null = default (steward-only control).
  /// Future purpose: governs player agency over lore, story arcs, NPC interactions,
  /// and world-state mutations within this campaign.
  /// Expected shape (L3): {
  /// ownershipModel: "steward_only" | "collaborative" | "player_sovereign",
  /// playerAgency: { canEditLore: boolean, canBranchArcs: boolean, canSpawnNpcs: boolean },
  /// loreEditPolicy: "append_only" | "propose_review" | "direct_edit",
  /// storyArcPermissions: { canCreate: Role[], canModify: Role[], canArchive: Role[] },
  /// npcInteractionPolicy: "scripted" | "semi_autonomous" | "player_directed"
  /// }
  /// Constraints: validated at application layer; ownershipModel required when non-null;
  /// Role references must be valid BARS roles (owner/steward/admin/player).
  narrativeSovereignty Json?
  /// Phase 2a: Inherited world properties (read-only snapshot)
  /// Populated at campaign creation from Instance. Immutable once set.
  /// Shape: { nations, emotionalAlchemy, moves, gates, ... } — frozen at creation time
  inheritedWorld       Json?
  /// Phase 2a: Campaign flavor layers (customizable by GM)
  /// GM-editable contextualization on top of inherited world.
  /// Shape: { scope, real_world_context, quest_generation, invite_config, ... }
  /// See PHASE2A_BACKFILL_LOGIC_DESIGN.md for full schema.
  campaignFlavorLayers Json?
  /// DAOE Phase 3: Player Personality Intake — stored player profile + NPC tone weights
  personalityProfile  Json?
  /// DAOE Phase 4: Campaign suspension kill-switch — set when subscription revoked, cleared on restore
  suspendedAt          DateTime?
  /// Scheduled start
  startDate            DateTime?
  /// Scheduled end
  endDate              DateTime?
  /// --- Relations ---
  instanceId           String
  /// Optional parent initiative (subcampaign). Must stay in the same `instanceId`; cycles forbidden (enforced in app).
  /// On parent delete, children become root-level campaigns (`parentCampaignId` set null).
  parentCampaignId     String?
  /// Steward+ who created the campaign
  createdById          String
  /// Timestamp when campaign was submitted for review
  submittedAt          DateTime?
  /// Admin who reviewed (approved or rejected) the campaign
  reviewedById         String?
  /// Timestamp when the review decision was made
  reviewedAt           DateTime?
  /// Reason for rejection (populated when status = REJECTED)
  rejectionReason      String?
  /// Shareable public URL — generated on approval (null while DRAFT/PENDING_REVIEW)
  shareUrl             String?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  loreEntries          CampaignLoreEntry[]
  memberships          CampaignMembership[] @relation("CampaignMemberships")
  theme                CampaignTheme?
  createdBy            Player               @relation("CampaignsCreated", fields: [createdById], references: [id], onDelete: Cascade)
  instance             Instance             @relation("InstanceCampaigns", fields: [instanceId], references: [id], onDelete: Cascade)
  parentCampaign       Campaign?            @relation("CampaignHierarchy", fields: [parentCampaignId], references: [id])
  childCampaigns       Campaign[]           @relation("CampaignHierarchy")
  reviewedBy           Player?              @relation("CampaignsReviewed", fields: [reviewedById], references: [id])
  invites              Invite[]             @relation("CampaignInvites")
  storyArcTemplates    StoryArcTemplate[]

  @@index([instanceId, status])
  @@index([status])
  @@index([parentCampaignId])
  @@map("campaigns")
}

/// L2: Visual skin for a campaign — extends getCampaignSkin() to be DB-driven.
/// CSS custom properties applied via wrapper element (see campaign-skin.ts).
///
/// Three-layer theming (lowest → highest priority):
/// 1. Static skin (getCampaignSkin) — code-defined baseline per campaignRef
/// 2. Database theme (these typed columns) — strategic overrides from L2 wizard
/// 3. cssVarOverrides Json — power-user full CSS var control
///
/// Typed columns cover the L2 wizard surfaces; JSON fields cover
/// three-channel encoding (element→color, altitude→border, stage→density).
/// Phase 3: Campaign membership — who is a member/steward/owner
/// See .specify/specs/phase-3-stewardship/SPEC.md
model CampaignMembership {
  id           String         @id @default(cuid())
  campaignId   String
  playerId     String
  role         MembershipRole
  /// null unless role = STEWARD; FULL = general steward
  stewardScope StewardScope?
  createdAt    DateTime       @default(now())
  campaign     Campaign       @relation("CampaignMemberships", fields: [campaignId], references: [id], onDelete: Cascade, map: "campaign_memberships_campaign_id_fkey")
  player       Player         @relation("PlayerMemberships", fields: [playerId], references: [id], onDelete: Cascade, map: "campaign_memberships_player_id_fkey")

  @@unique([campaignId, playerId])
  @@index([campaignId])
  @@index([playerId])
  @@map("campaign_memberships")
}

model CampaignTheme {
  id                String   @id @default(cuid())
  campaignId        String   @unique
  /// CSS gradient string (e.g. "linear-gradient(180deg, #1a1a5e 0%, #2b2b8a 30%, #1a1a5e 100%)")
  bgGradient        String?
  /// Background deep color (hex) — used for solid fills behind gradient
  bgDeep            String?
  /// Title/heading color (hex)
  titleColor        String?
  /// Primary accent (hex) — main brand color
  accentPrimary     String?
  /// Secondary accent (hex) — complementary highlights
  accentSecondary   String?
  /// Tertiary accent (hex) — decorative / tertiary highlights
  accentTertiary    String?
  /// Success/progress color (hex) — defaults to --cs-green (#4ade80)
  greenAccent       String?
  /// Card/surface background (CSS color, e.g. "rgba(10, 10, 40, 0.6)")
  surfaceColor      String?
  /// Surface hover state (CSS color)
  surfaceHoverColor String?
  /// Surface border default (CSS color, e.g. "rgba(200, 160, 255, 0.15)")
  borderColor       String?
  /// Surface border hover (CSS color)
  borderHoverColor  String?
  /// Primary text color (hex) — main body/heading text
  textPrimary       String?
  /// Secondary text color (hex) — sub-headings, captions
  textSecondary     String?
  /// Muted text color (hex) — timestamps, disabled states (only ≥ text-sm)
  textMuted         String?
  /// Primary CTA background (hex)
  ctaBg             String?
  /// Primary CTA text color (hex)
  ctaText           String?
  /// Primary CTA hover background (hex)
  ctaHoverBg        String?
  /// Display font key (e.g. "press-start-2p") from approved font list — headings
  fontDisplayKey    String?
  /// Body font key (e.g. "inter", "dm-sans") — paragraph text
  fontBodyKey       String?
  /// Uploaded campaign poster/banner URL
  posterImageUrl    String?
  /// Border tokens: altitude channel encoding { borderRadius, borderWidth, glowRadius, glowColor }
  /// See CampaignBorderTokens type in src/lib/ui/campaign-skin-tokens.ts
  borderTokens      Json?
  /// Density tokens: stage channel encoding { cardPadding, sectionSpacing, contentDensity }
  /// See CampaignDensityTokens type in src/lib/ui/campaign-skin-tokens.ts
  densityTokens     Json?
  /// Full CSS var override JSON — power-user layer (highest priority)
  cssVarOverrides   Json?
  /// L3: Reserved — narrative theming config for visual storytelling surfaces.
  /// DO NOT populate until L3 implementation ships. Null = no narrative visual overrides.
  /// Future purpose: CYOA scene skin overrides, NPC portrait/avatar URLs,
  /// story arc phase tinting (color shifts per narrative beat), and lore card styling.
  /// Expected shape (L3): {
  /// cyoaSkin?: { sceneBackgrounds: Record<string, string>, transitionEffect: string },
  /// npcPortraits?: Record<string, { url: string, fallbackColor: string }>,
  /// arcTinting?: Record<string, { bgOverride: string, accentOverride: string }>,
  /// loreCardStyle?: { borderPattern: string, headerFont: string }
  /// }
  /// Constraints: validated at application layer; URL fields must be sanitized;
  /// inherits from CampaignTheme typed columns (this layer is additive, not replacing).
  narrativeConfig   Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  campaign          Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@map("campaign_themes")
}

/// Campaign Self-Serve: Reusable quest templates for the L1 wizard.
/// Steward+ picks a template → customizes via copyTemplate overlay → attaches to Campaign.
/// category groups templates in the wizard UI (e.g. "onboarding", "fundraising", "awareness").
/// defaultSettings: canonical template config (read-only to end users).
/// copyTemplate: JSON blueprint that the wizard clones + lets the steward override per-campaign.
/// L3-ready: narrativeHooks field reserved for future narrative sovereignty extensions.
/// When L3 ships, narrativeHooks will wire quest completion to narrative world-state changes.
model QuestTemplate {
  id              String   @id @default(cuid())
  /// Unique machine key (e.g. "onboarding-welcome", "fundraiser-pledge")
  key             String   @unique
  /// Human-readable template name shown in wizard
  name            String
  /// Longer description / helper text for the wizard
  description     String?
  /// Wizard grouping: onboarding | fundraising | awareness | direct_action | community | custom
  category        String
  /// Canonical default settings for this template type (JSON)
  defaultSettings Json     @default("{}")
  /// Blueprint JSON cloned into Campaign.questTemplateConfig when selected
  copyTemplate    Json     @default("{}")
  /// L3: Reserved — narrative hooks wiring quest templates to narrative sovereignty features.
  /// DO NOT populate until L3 implementation ships. Null = template has no narrative integration.
  /// Future purpose: connects a quest template to CYOA graph entry points, NPC encounter triggers,
  /// lore unlock conditions, and story arc beat transitions.
  /// Expected shape (L3): {
  /// cyoaEntryPoints?: { graphId: string, nodeId: string }[],
  /// npcTriggers?: { constitutionId: string, encounterType: string, condition: object }[],
  /// loreUnlocks?: { loreEntryId: string, unlockCondition: object }[],
  /// arcBeatTransitions?: { arcId: string, fromBeat: string, toBeat: string }[]
  /// }
  /// Constraints: validated at application layer; all ID references must resolve;
  /// hooks are read-only to players — only steward+ can configure via admin UI.
  narrativeHooks  Json?
  /// soft-archive: active | archived
  status          String   @default("active")
  /// Display ordering within category
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([category, status])
  @@map("quest_templates")
}

/// L3: Lore entries for campaign narrative world-building.
/// Each entry represents a canonical piece of campaign lore (characters, places, factions, events).
/// ╔═══════════════════════════════════════════════════════════════════════════════╗
/// ║ DEFERRED FOR L3 — DO NOT create rows until L3 implementation ships.         ║
/// ║ Schema reserved now for forward compatibility so no migration needed at L3. ║
/// ╚═══════════════════════════════════════════════════════════════════════════════╝
///
/// Future purpose: populates a campaign wiki/codex surface where stewards (and optionally
/// players, per Campaign.narrativeSovereignty.loreEditPolicy) can build out the narrative
/// world. Lore entries feed into NPC encounter context, CYOA scene descriptions, and
/// quest narrative generation.
///
/// Access control: governed by Campaign.narrativeSovereignty — steward_only by default.
/// When loreEditPolicy = "propose_review", player-authored entries start as draft pending
/// steward approval. When "append_only", players can add but not modify existing entries.
///
/// Constraints:
/// - category must be one of: character | place | faction | event | item | custom
/// - content supports markdown; max recommended length 10,000 chars (app-layer validation)
/// - metadata shape varies by category (validated at app layer):
/// character: { portraitUrl?, tags?, relationships?: { targetEntryId, type }[] }
/// place:     { coordinates?, mapRegion?, tags? }
/// faction:   { alignment?, memberEntryIds?, tags? }
/// event:     { timelinePosition?, linkedArcId?, tags? }
/// item:      { rarity?, effectDescription?, tags? }
/// custom:    { [key: string]: unknown }
/// - All URL fields in metadata must be sanitized at application layer
/// - createdById tracks authorship for sovereignty audit trail
model CampaignLoreEntry {
  id          String   @id @default(cuid())
  campaignId  String
  /// Lore category: character | place | faction | event | item | custom
  /// Validated at application layer — must match one of the above values.
  category    String
  /// Entry title (e.g. "The Bruised Banana", "Giacomo")
  title       String
  /// Rich lore content (markdown). Max recommended 10,000 chars (app-layer).
  content     String?
  /// Structured metadata — shape depends on category (see model-level docs above).
  /// Validated at application layer per category-specific schema.
  metadata    Json?
  /// Ordering within category (0-based, ascending)
  sortOrder   Int      @default(0)
  /// soft-archive: active | archived — archived entries hidden from players but preserved
  status      String   @default("active")
  /// Who authored this lore entry — required for sovereignty audit trail.
  /// Null = system-generated (e.g. backfilled from Bruised Banana reference data).
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  createdBy   Player?  @relation("LoreEntriesCreated", fields: [createdById], references: [id])

  @@index([campaignId, category, status])
  @@map("campaign_lore_entries")
}

/// L3: Story arc templates defining narrative structure for campaigns.
/// Represents a reusable or per-campaign story arc (act structure, beat sheets, branching paths).
/// ╔═══════════════════════════════════════════════════════════════════════════════╗
/// ║ DEFERRED FOR L3 — DO NOT create rows until L3 implementation ships.         ║
/// ║ Schema reserved now for forward compatibility so no migration needed at L3. ║
/// ╚═══════════════════════════════════════════════════════════════════════════════╝
///
/// Future purpose: drives campaign narrative pacing by defining story beats, branching
/// decision points, and phase transitions. Arcs can be shared across campaigns (via
/// clone-and-customize) or unique to one campaign.
///
/// Integration points:
/// - CampaignLoreEntry: lore events can reference arc beats via metadata.linkedArcId
/// - QuestTemplate.narrativeHooks.arcBeatTransitions: quests trigger arc phase changes
/// - Campaign.narrativeSovereignty.storyArcPermissions: controls who can edit arcs
/// - CampaignTheme.narrativeConfig.arcTinting: visual changes per arc phase
///
/// Constraints:
/// - arcType must be one of: linear | branching | cyclical | emergent
/// - definition shape depends on arcType (validated at application layer):
/// linear:    { beats: { id, title, description, order }[] }
/// branching: { beats: ..., branches: { fromBeatId, toBeatId, condition }[] }
/// cyclical:  { beats: ..., cycleCondition: object, maxCycles?: number }
/// emergent:  { seeds: { trigger, outcome }[], emergenceRules: object }
/// - definition must not exceed 256KB (app-layer validation)
/// - sovereignty field inherits from Campaign.narrativeSovereignty when null
model StoryArcTemplate {
  id          String   @id @default(cuid())
  campaignId  String
  /// Arc name (e.g. "Hero's Journey", "Three Act Structure", custom)
  name        String
  /// Arc description — shown in arc selection UI and narrative timeline
  description String?
  /// Arc type: linear | branching | cyclical | emergent
  /// Determines the expected shape of the definition JSON field.
  arcType     String   @default("linear")
  /// Full arc definition: beats, branches, conditions, triggers.
  /// Shape depends on arcType — see model-level docs for per-type schemas.
  /// Validated at application layer; must not exceed 256KB.
  definition  Json     @default("{}")
  /// L3 narrative sovereignty: per-arc permission overrides.
  /// When null, inherits from Campaign.narrativeSovereignty.storyArcPermissions.
  /// When set, overrides the campaign-level permissions for this specific arc.
  /// Expected shape (L3): {
  /// canModifyBeats: Role[],   // who can add/edit/reorder beats
  /// canBranch: Role[],        // who can create new branches
  /// canAdvancePhase: Role[],  // who can trigger beat transitions
  /// isLocked: boolean         // true = frozen, no modifications allowed
  /// }
  /// Constraints: Role references must be valid BARS roles; validated at app layer.
  sovereignty Json?
  /// soft-archive: active | archived — archived arcs preserved but hidden from active campaign
  status      String   @default("active")
  /// Display ordering (0-based, ascending)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId, status])
  @@map("story_arc_templates")
}

model NarrativeTemplate {
  id             String                @id @default(cuid())
  key            String                @unique
  name           String
  description    String?
  kind           NarrativeTemplateKind
  stepCount      Int
  faceAffinities Json                  @default("[]")
  questModel     String                @default("personal")
  configBlob     Json                  @default("{}")
  status         String                @default("active")
  sortOrder      Int                   @default(0)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@index([kind, status])
  @@map("narrative_templates")
}

model School {
  id           String    @id @default(cuid())
  name         String
  description  String    @default("")
  portraysFace String
  nationId     String?
  instanceId   String?
  imgUrl       String?
  archived     Boolean   @default(false)
  sortOrder    Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  instance     Instance? @relation("SchoolInstance", fields: [instanceId], references: [id], onDelete: Cascade)
  nation       Nation?   @relation(fields: [nationId], references: [id], onDelete: Cascade)

  @@index([portraysFace])
  @@index([nationId])
  @@index([instanceId])
  @@map("schools")
}

model ChapterRegistration {
  id           String   @id @default(cuid())
  chapterRef   String   @unique
  bookRef      String
  orgRef       String
  version      String   @default("v1")
  definition   Json
  registeredAt DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([bookRef])
  @@index([orgRef])
  @@map("chapter_registrations")
}

model PlayerChapterProgress {
  id             String   @id @default(cuid())
  playerId       String
  chapterRef     String
  firstEnteredAt DateTime @default(now())
  lastEnteredAt  DateTime @default(now())
  enterCount     Int      @default(1)
  barCount       Int      @default(0)
  completed      Boolean  @default(false)
  player         Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([playerId, chapterRef])
  @@index([playerId])
  @@index([chapterRef])
  @@map("player_chapter_progress")
}

model ChapterMilestone {
  id                 String   @id @default(cuid())
  chapterRef         String   @unique
  bookRef            String
  title              String
  description        String
  parentMilestoneRef String?
  rollupWeight       Float    @default(1.0)
  minBarsRequired    Int      @default(1)
  totalBarCount      Int      @default(0)
  totalPlayerCount   Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([bookRef])
  @@map("chapter_milestones")
}

/// CHS campaign backbone: fixed 52 or 64 content slots; draw uses only bound slots (see campaign-hub-spoke-landing-architecture spec).
enum CampaignDeckTopology {
  CAMPAIGN_DECK_52
  CAMPAIGN_DECK_64
}

/// Deck type enumeration for BarDeck variants
enum DeckType {
  SCENE_ATLAS
  FRIENDSHIP_52
  FRIENDSHIP_64
}

/// Campaign Self-Serve (CSS): L1 wizard + L2 skinning + L3 schema-ready
/// Instance:Campaign is 1:many — campaigns live inside an Instance (the world/venue).
/// Steward+ creates → draft → pending_review → approved/rejected → live → archived.
enum CampaignStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
  LIVE
  ABANDONED
  ARCHIVED
}

/// Phase 3: Who can do what in a campaign
/// See .specify/specs/phase-3-stewardship/SPEC.md
enum MembershipRole {
  /// Can view + participate in stewarded content
  MEMBER
  /// Can create/edit within own stewardship scope
  STEWARD
  /// Campaign creator; can promote/demote, set discoverability
  OWNER
}

/// Phase 3: Granular stewardship scope per spoke
/// Derived from campaign deck type at campaign initialization
enum StewardScope {
  /// General steward — can touch everything
  FULL
  /// Owns campaign deck structure
  DECK
  /// Owns spoke domain 1
  SPOKE_1
  SPOKE_2
  SPOKE_3
  SPOKE_4
  SPOKE_5
  SPOKE_6
  SPOKE_7
  SPOKE_8
}

enum NarrativeTemplateKind {
  EPIPHANY
  KOTTER
  ORIENTATION
  CUSTOM
}
