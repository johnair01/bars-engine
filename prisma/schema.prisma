generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

model Invite {
  id                 String    @id @default(cuid())
  token              String    @unique
  status             String    @default("active")
  preassignedRoleKey String?
  maxUses            Int       @default(1)
  uses               Int       @default(0)
  theme              String    @default("standard")
  createdAt          DateTime  @default(now())
  usedAt             DateTime?
  players            Player[]  @relation("InviteUsed")

  @@map("invites")
}

model Player {
  id                     String                     @id @default(cuid())
  accountId              String?
  name                   String
  contactType            String
  contactValue           String
  passwordHash           String?
  onboardingMode         String?                    @default("expert")
  onboardingComplete     Boolean                    @default(false)
  storyProgress          String?
  hasSeenWelcome         Boolean                    @default(false)
  hasSeenCampaignEntry   Boolean                    @default(false)
  hasCompletedFirstQuest Boolean                    @default(false)
  hasCreatedFirstQuest   Boolean                    @default(false)
  onboardingCompletedAt  DateTime?
  inviteId               String
  nationId               String?
  archetypeId            String?
  campaignDomainPreference String?   // JSON array: ["GATHERING_RESOURCES","DIRECT_ACTION"]; null or [] = show all
  avatarConfig            String?   // JSON: { nationKey, archetypeKey, domainKey, variant } derived from CYOA choices
  pronouns               String?
  attendance             String?
  createdAt              DateTime                   @default(now())
  barSharesSent          BarShare[]                 @relation("BarSharesSent")
  barSharesReceived      BarShare[]                 @relation("BarSharesReceived")
  claimedBars            CustomBar[]                @relation("ClaimedBars")
  createdBars            CustomBar[]                @relation("CreatedBars")
  donations              Donation[]
  emotionalAidSessions   EmotionalFirstAidSession[]
  instanceMemberships    InstanceMembership[]
  bars                   PlayerBar[]
  nationMoveUnlocks      PlayerNationMoveUnlock[]
  moveEquips             PlayerMoveEquip[]
  moveUses               MoveUse[]
  barResponses           BarResponse[]
  quests                 PlayerQuest[]
  roles                  PlayerRole[]
  account                Account?                   @relation(fields: [accountId], references: [id])
  invite                 Invite                     @relation("InviteUsed", fields: [inviteId], references: [id])
  nation                 Nation?                    @relation(fields: [nationId], references: [id])
  archetype              Archetype?                @relation(fields: [archetypeId], references: [id])
  questMoveLogs          QuestMoveLog[]
  starterPack            StarterPack?
  twineBindingsCreated   TwineBinding[]             @relation("TwineBindingsCreated")
  twineRunsPlayed        TwineRun[]                 @relation("TwineRunsPlayed")
  twineStoriesCreated    TwineStory[]               @relation("TwineStoriesCreated")
  vibulonEvents          VibulonEvent[]
  vibulons               Vibulon[]
  creatorVibulons        Vibulon[]                 @relation("VibulonCreator")
  vibeulonLedger         VibeulonLedger[]
  participations         InstanceParticipation[]
  adventureProgress      PlayerAdventureProgress[]
  redemptionPacks        RedemptionPack[]
  libraryRequests        LibraryRequest[]
  bookAnalysisResumeLogs BookAnalysisResumeLog[]
  verificationCompletionLogs VerificationCompletionLog[]
  stewardedSlots         GameboardSlot[] @relation("GameboardSteward")
  gameboardBids         GameboardBid[]
  gameboardAidOffersMade GameboardAidOffer[] @relation("GameboardAidOfferer")
  gameboardAidOffersReceived GameboardAidOffer[] @relation("GameboardAidSteward")
  questProposals       QuestProposal[]
  bountyStakes         BountyStake[]
  shadow321Sessions    Shadow321Session[]
  eventArtifactsCreated EventArtifact[]     @relation("EventArtifactCreator")
  eventParticipations   EventParticipant[]  @relation("EventParticipantAsParticipant")
  eventInvitesReceived  EventInvite[]       @relation("EventInviteReceived")
  eventInvitesSent      EventInvite[]       @relation("EventInviteSent")
  orientationSessions  OrientationSession[]
  daemons              Daemon[]
  daemonSummons        DaemonSummon[]
  blessedObjectsEarned BlessedObjectEarned[]
  playerPlaybooks      PlayerPlaybook[]
  alchemyPlayerState   AlchemyPlayerState?
  alchemySceneEvents   AlchemySceneEvent[]
  npcMemories          NpcMemory[]
  npcRelationships     NpcRelationshipState[]
  growthScenes         GrowthScene[]
  alchemyCheckIns      AlchemyCheckIn[]
  thresholdEncounters  ThresholdEncounter[]
  instanceExportRequests InstanceExportRequest[]

  @@unique([contactType, contactValue])
  @@map("players")
}

model Role {
  id           String       @id @default(cuid())
  key          String       @unique
  displayName  String
  description  String
  isForecasted Boolean      @default(false)
  createdAt    DateTime     @default(now())
  players      PlayerRole[]

  @@map("roles")
}

model Account {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  players      Player[]

  @@map("accounts")
}

model PlayerRole {
  id               String    @id @default(cuid())
  playerId         String
  roleId           String
  grantedByAdminId String?
  grantedAt        DateTime  @default(now())
  expiresAt        DateTime?
  player           Player    @relation(fields: [playerId], references: [id])
  role             Role      @relation(fields: [roleId], references: [id])

  @@unique([playerId, roleId])
  @@map("player_roles")
}

model Bar {
  id         Int         @id
  name       String
  tone       String
  text       String
  createdAt  DateTime    @default(now())
  assignedTo PlayerBar[]

  @@map("bars")
}

model CustomBar {
  id                   String         @id @default(cuid())
  creatorId            String
  title                String
  description          String
  type                 String         @default("vibe")
  reward               Int            @default(1)
  visibility           String         @default("public")
  claimedById          String?
  storyPath            String?
  allowedTrigrams      String?
  inputs               String         @default("[]")
  moveType             String?
  status               String         @default("active")
  kotterStage          Int            @default(1)
  storyContent         String?
  storyMood            String?
  isSystem             Boolean        @default(false)
  hexagramId           Int?
  periodGenerated      Int?
  firstCompleterId     String?
  maxAssignments       Int            @default(1)
  createdAt            DateTime       @default(now())
  parentId             String?
  twineLogic           String?
  completionEffects    String?
  rootId               String?
  allowedNations       String?
  allyshipDomain       String?      // GATHERING_RESOURCES | DIRECT_ACTION | RAISE_AWARENESS | SKILLFUL_ORGANIZING
  nation               String?      // thematic nation (Argyra, Pyrakanth, etc.) from book analysis
  archetype            String?      // thematic archetype (Bold Heart, Danger Walker, etc.) from book analysis
  lockType             String?      // identity_lock | emotional_lock | action | possibility (transformation alignment)
  campaignRef          String?      // e.g. bruised-banana; when set, quest is campaign-linked
  campaignGoal         String?      // e.g. throw a party; the goal this quest fulfills
  emotionalAlchemyTag  String?      // aligned | curious | skeptical; when set, quest preferred for that onboarding branch
  forkedFromId         String?      // when set, this quest is a private fork of another
  gameMasterFace       String?      // shaman | challenger | regent | architect | diplomat | sage (dojo alignment for growUp)
  twineStoryId         String?
  docQuestMetadata     String?   // JSON: { docIntent, targetDocNodeId, targetLibraryRequestId, schismId, validationChecklist, barRequirements }
  backlogPromptPath    String?   // e.g. .specify/specs/lore-cyoa-onboarding/spec.md (verification quest → backlog update)
  evidenceKind         String?   // observation | instruction | canon_statement | spec_clause | lore | schism (when CustomBar is evidence)
  sourceBarId          String?   // when set, this quest was generated from this BAR (BAR → Quest Generation Engine)
  source321SessionId   String?   // when set, this quest was created from 321 session (Singleplayer Charge Metabolism)
  isKeyUnblocker       Boolean   @default(false) // tetris: completing this subquest unblocks root + siblings
  grantsMoveId         String?   // when set, completing this quest unlocks this NationMove
  questSource          String?   // system | bounty; bounties have stakedPool > 0
  stakedPool           Int       @default(0) // vibeulons in escrow for bounty payouts
  agentMetadata        String?   // JSON: { agent, deterministic, confidence, reasoning, discernedMove, usageTokens }
  questPool            String?   // efa | dojo | discovery | gameboard — wave routing for book-derived quests
  shares               BarShare[]
  bountyStakes         BountyStake[]
  claimedBy            Player?        @relation("ClaimedBars", fields: [claimedById], references: [id])
  creator              Player         @relation("CreatedBars", fields: [creatorId], references: [id])
  parent               CustomBar?     @relation("CustomBarTree", fields: [parentId], references: [id])
  children             CustomBar[]    @relation("CustomBarTree")
  forkedFrom           CustomBar?     @relation("QuestFork", fields: [forkedFromId], references: [id], onDelete: SetNull)
  forks                CustomBar[]   @relation("QuestFork")
  twineStory           TwineStory?    @relation(fields: [twineStoryId], references: [id])
  packQuests           PackQuest[]
  assignments          PlayerQuest[]
  moveLogsAsCreatedBar QuestMoveLog[] @relation("QuestMoveCreatedBar")
  questMoveLogs        QuestMoveLog[] @relation("QuestMoveQuest")
  threadQuests         ThreadQuest[]
  linkedPassages       Passage[]      @relation("PassageLinkedQuest")
  upgradedThreads      QuestThread[]  @relation("QuestUpgradeProvenance")
  microTwine           MicroTwineModule?
  libraryRequestsSpawned LibraryRequest[] @relation("LibraryRequestSpawnedQuest")
  gameboardSlots       GameboardSlot[]
  aidOffersLinked     GameboardAidOffer[] @relation("AidOfferLinkedQuest")
  sourceBar           CustomBar?          @relation("BarConversion", fields: [sourceBarId], references: [id], onDelete: SetNull)
  questsFromBar       CustomBar[]         @relation("BarConversion")
  questProposals      QuestProposal[]
  responses           BarResponse[]
  bindings            BarBinding[]

  @@map("custom_bars")
}

model Shadow321Session {
  id               String    @id @default(cuid())
  playerId         String
  createdAt        DateTime  @default(now())
  phase3Snapshot   String    // JSON: archetypeName, nationName, developmentalLens, genderOfCharge
  phase2Snapshot   String    // JSON: q1, q5, alignedAction, moveType
  outcome          String    // bar_created | quest_created | fueled_system | skipped
  linkedBarId      String?
  linkedQuestId    String?
  questCompletedAt DateTime?

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId])
  @@index([outcome])
  @@map("shadow_321_sessions")
}

model Daemon {
  id           String   @id @default(cuid())
  playerId     String
  name         String
  source       String   // 321_wake_up | school
  level        Int      @default(1)
  moveIds      String   @default("[]") // JSON array of NationMove ids
  discoveredAt DateTime @default(now())

  player  Player         @relation(fields: [playerId], references: [id], onDelete: Cascade)
  summons DaemonSummon[]

  @@index([playerId])
  @@map("daemons")
}

model DaemonSummon {
  id        String     @id @default(cuid())
  daemonId  String
  playerId  String
  summonedAt DateTime   @default(now())
  expiresAt  DateTime
  status    String     @default("active") // active | dismissed

  daemon Daemon @relation(fields: [daemonId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([daemonId])
  @@index([playerId])
  @@index([status, expiresAt])
  @@map("daemon_summons")
}

model BlessedObjectEarned {
  id          String    @id @default(cuid())
  playerId    String
  source      String    // efa | 321 | stage_talisman | campaign_completion | personal
  earnedAt    DateTime  @default(now())
  instanceId  String?
  kotterStage Int?
  questId     String?
  metadata    Json?     // extra provenance: loreBarId, etc.

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId])
  @@index([playerId, source, instanceId, kotterStage])
  @@map("blessed_objects_earned")
}

model QuestProposal {
  id                    String   @id @default(cuid())
  barId                 String
  campaignRef           String?  // e.g. bruised-banana; from BAR or context
  playerId              String
  title                 String
  description           String   @db.Text
  domain                String?  // allyship domain: GATHERING_RESOURCES | DIRECT_ACTION | RAISE_AWARENESS | SKILLFUL_ORGANIZING
  questType             String?  // resource | coordination | awareness | action | reflection
  completionConditions  String   @default("[]") // JSON array
  emotionalAlchemy      String   @default("{}") // JSON: { status, moveId, moveName, prompt, completionReflection }
  reviewStatus          String   @default("pending") // pending | approved | rejected | deferred
  confidenceScore      Float    @default(0)
  publishedQuestId      String?  // set when published; links to created CustomBar
  createdAt             DateTime @default(now())

  bar     CustomBar @relation(fields: [barId], references: [id], onDelete: Cascade)
  player  Player    @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([barId])
  @@index([reviewStatus])
  @@index([campaignRef, reviewStatus])
  @@map("quest_proposals")
}

model PlayerBar {
  id         String   @id @default(cuid())
  playerId   String
  barId      Int
  source     String
  notes      String?
  acquiredAt DateTime @default(now())
  bar        Bar      @relation(fields: [barId], references: [id])
  player     Player   @relation(fields: [playerId], references: [id])

  @@index([playerId, source])
  @@map("player_bars")
}

model BarShare {
  id         String    @id @default(cuid())
  barId      String
  fromUserId String
  toUserId   String
  note       String?
  createdAt  DateTime  @default(now())
  bar        CustomBar @relation(fields: [barId], references: [id], onDelete: Cascade)
  fromUser   Player    @relation("BarSharesSent", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser     Player    @relation("BarSharesReceived", fields: [toUserId], references: [id], onDelete: Cascade)

  @@index([fromUserId, createdAt])
  @@index([toUserId, createdAt])
  @@index([barId, createdAt])
  @@map("bar_shares")
}

model BarResponse {
  id           String   @id @default(cuid())
  barId        String
  responderId  String
  responseType String   // join | curious | witness | offer_help | decline | cant_help | appreciate
  message      String?  @db.Text
  createdAt    DateTime @default(now())

  bar       CustomBar @relation(fields: [barId], references: [id], onDelete: Cascade)
  responder Player    @relation(fields: [responderId], references: [id], onDelete: Cascade)

  @@unique([barId, responderId])
  @@index([barId])
  @@index([responderId])
  @@map("bar_responses")
}

model Quest {
  id         String   @id @default(cuid())
  title      String
  prompt     String
  returnType String
  parentId   String?
  rootId     String?
  createdAt  DateTime @default(now())
  parent     Quest?   @relation("QuestTree", fields: [parentId], references: [id])
  children   Quest[]  @relation("QuestTree")

  @@map("quests")
}

model PlayerQuest {
  id          String    @id @default(cuid())
  playerId    String
  questId     String
  status      String    @default("assigned")
  inputs      String?
  assignedAt  DateTime  @default(now())
  completedAt DateTime?
  player      Player    @relation(fields: [playerId], references: [id])
  quest       CustomBar @relation(fields: [questId], references: [id])

  @@unique([playerId, questId])
  @@map("player_quests")
}

model Book {
  id                   String                 @id @default(cuid())
  title                String
  author               String?
  slug                 String                 @unique
  sourcePdfUrl         String?
  extractedText        String?                @db.Text
  status               String                 @default("draft") // draft | extracted | analyzed | published
  metadataJson         String?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  thread               QuestThread?
  bookAnalysisResumeLogs BookAnalysisResumeLog[]

  @@map("books")
}

model BookAnalysisResumeLog {
  id        String   @id @default(cuid())
  adminId   String
  bookId    String
  createdAt DateTime @default(now())
  admin     Player   @relation(fields: [adminId], references: [id])
  book      Book     @relation(fields: [bookId], references: [id])

  @@index([adminId, createdAt])
  @@map("book_analysis_resume_logs")
}

model VerificationCompletionLog {
  id                String    @id @default(cuid())
  questId           String
  playerId          String
  backlogPromptPath String
  completedAt       DateTime  @default(now())
  syncedAt          DateTime?
  player            Player    @relation(fields: [playerId], references: [id])

  @@index([syncedAt])
  @@map("verification_completion_logs")
}

model QuestThread {
  id               String           @id @default(cuid())
  title            String
  description      String?
  threadType       String           @default("standard")
  creatorType      String           @default("system")
  creatorId        String?
  creationCost     Int              @default(0)
  completionReward Int              @default(0)
  allowedArchetypes String?
  gateNationId     String?
  gateArchetypeId  String?
  status           String           @default("active")
  createdAt        DateTime         @default(now())
  bookId           String?          @unique
  adventureId      String?          @unique
  eventCampaignId  String?          @unique // Event production quest thread
  sourceQuestId    String?          // Provenance: upgraded from this CustomBar (quest)
  book             Book?            @relation(fields: [bookId], references: [id])
  eventCampaign    EventCampaign?   @relation(fields: [eventCampaignId], references: [id], onDelete: SetNull)
  adventure        Adventure?       @relation(fields: [adventureId], references: [id], onDelete: SetNull)
  sourceQuest      CustomBar?       @relation("QuestUpgradeProvenance", fields: [sourceQuestId], references: [id])
  progress         ThreadProgress[]
  quests           ThreadQuest[]

  @@map("quest_threads")
}

model ThreadQuest {
  id       String      @id @default(cuid())
  threadId String
  questId  String
  position Int
  quest    CustomBar   @relation(fields: [questId], references: [id])
  thread   QuestThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@unique([threadId, position])
  @@unique([threadId, questId])
  @@map("thread_quests")
}

model ThreadProgress {
  id              String      @id @default(cuid())
  threadId        String
  playerId        String
  currentPosition Int         @default(0)
  startedAt       DateTime    @default(now())
  completedAt     DateTime?
  isArchived      Boolean     @default(false)
  thread          QuestThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@unique([threadId, playerId])
  @@map("thread_progress")
}

model QuestPack {
  id               String         @id @default(cuid())
  title            String
  description      String?
  creatorType      String         @default("system")
  creatorId        String?
  allowedArchetypes String?
  status           String         @default("active")
  visibility       String         @default("private")
  createdAt        DateTime       @default(now())
  progress         PackProgress[]
  quests           PackQuest[]

  @@map("quest_packs")
}

model PackQuest {
  id      String    @id @default(cuid())
  packId  String
  questId String
  pack    QuestPack @relation(fields: [packId], references: [id], onDelete: Cascade)
  quest   CustomBar @relation(fields: [questId], references: [id])

  @@unique([packId, questId])
  @@map("pack_quests")
}

model PackProgress {
  id          String    @id @default(cuid())
  packId      String
  playerId    String
  completed   String    @default("[]")
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  isArchived  Boolean   @default(false)
  pack        QuestPack @relation(fields: [packId], references: [id], onDelete: Cascade)

  @@unique([packId, playerId])
  @@map("pack_progress")
}

model VibulonEvent {
  id            String   @id @default(cuid())
  playerId      String
  source        String
  amount        Int
  notes         String?
  archetypeMove String?
  questId       String?
  createdAt     DateTime @default(now())
  player        Player   @relation(fields: [playerId], references: [id])

  @@map("vibulon_events")
}

model Vibulon {
  id            String   @id @default(cuid())
  ownerId       String?
  creatorId     String?  // Signature: who "signed" this vibeulon (EFA=self, BAR=quest creator)
  originSource  String
  originId      String
  originTitle   String
  generation    Int      @default(1)
  stakedOnBarId String?
  createdAt     DateTime @default(now())
  owner         Player?  @relation(fields: [ownerId], references: [id])
  creator       Player?  @relation("VibulonCreator", fields: [creatorId], references: [id])
  bountyStake   BountyStake?

  @@map("vibulons")
}

model Nation {
  id          String       @id @default(cuid())
  name        String
  description String
  element     String       @default("earth") // metal, water, wood, fire, earth — for choice privileging
  imgUrl      String?
  archived    Boolean      @default(false)
  wakeUp      String?
  cleanUp     String?
  growUp      String?
  showUp      String?
  instanceId  String?      // null = global; non-null = instance-scoped
  createdAt   DateTime     @default(now())
  moves       NationMove[]
  players     Player[]
  instance    Instance?    @relation("NationInstance", fields: [instanceId], references: [id], onDelete: Cascade)

  @@index([instanceId])
  @@map("nations")
}

model Polarity {
  id          String       @id @default(cuid())
  key         String       @unique
  name        String
  description String?
  icon        String?
  createdAt   DateTime     @default(now())
  moves       NationMove[]

  @@map("polarities")
}

model NationMove {
  id                 String                   @id @default(cuid())
  key                String                   @unique
  nationId           String
  archetypeId        String?                  // when set, move is in archetype pool for this archetype
  polarityId         String?
  name               String
  description        String
  isStartingUnlocked Boolean                  @default(false)
  usesPerPeriod      Int                      @default(2) // 0 = unlimited; max uses per period (daily)
  appliesToStatus    String                   @default("[]")
  requirementsSchema String                   @default("{}")
  effectsSchema      String                   @default("{}")
  sortOrder          Int                      @default(0)
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  nation             Nation                   @relation(fields: [nationId], references: [id], onDelete: Cascade)
  archetype          Archetype?               @relation(fields: [archetypeId], references: [id], onDelete: SetNull)
  polarity           Polarity?                @relation(fields: [polarityId], references: [id])
  unlocks            PlayerNationMoveUnlock[]
  logs               QuestMoveLog[]
  equipSlots         PlayerMoveEquip[]
  uses               MoveUse[]

  @@index([nationId, sortOrder])
  @@map("nation_moves")
}

model PlayerNationMoveUnlock {
  id         String     @id @default(cuid())
  playerId   String
  moveId     String
  unlockedAt DateTime   @default(now())
  move       NationMove @relation(fields: [moveId], references: [id], onDelete: Cascade)
  player     Player     @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([playerId, moveId])
  @@index([moveId, unlockedAt])
  @@map("player_nation_move_unlocks")
}

model PlayerMoveEquip {
  id         String     @id @default(cuid())
  playerId   String
  slotIndex  Int        // 1-4
  moveId     String
  equippedAt DateTime   @default(now())
  move       NationMove @relation(fields: [moveId], references: [id], onDelete: Cascade)
  player     Player     @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([playerId, slotIndex])
  @@unique([playerId, moveId])
  @@index([playerId])
  @@map("player_move_equips")
}

model MoveUse {
  id        String     @id @default(cuid())
  playerId  String
  moveId    String
  periodKey String     // e.g. "2025-03-02" for daily
  usedAt    DateTime   @default(now())
  questId   String?
  move      NationMove @relation(fields: [moveId], references: [id], onDelete: Cascade)
  player    Player     @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId, moveId, periodKey])
  @@map("move_uses")
}

model QuestMoveLog {
  id           String     @id @default(cuid())
  questId      String
  moveId       String
  playerId     String
  createdBarId String?
  inputsJson   String?
  effectsJson  String?
  createdAt    DateTime   @default(now())
  createdBar   CustomBar? @relation("QuestMoveCreatedBar", fields: [createdBarId], references: [id])
  move         NationMove @relation(fields: [moveId], references: [id], onDelete: Cascade)
  player       Player     @relation(fields: [playerId], references: [id], onDelete: Cascade)
  quest        CustomBar  @relation("QuestMoveQuest", fields: [questId], references: [id], onDelete: Cascade)

  @@index([questId, createdAt])
  @@index([playerId, createdAt])
  @@map("quest_move_logs")
}

model Archetype {
  id                String   @id @default(cuid())
  name              String
  description       String
  moves             String
  content           String?
  centralConflict   String?
  primaryQuestion   String?
  vibe              String?
  energy            String?
  shadowSignposts   String?
  lightSignposts    String?
  examples          String?
