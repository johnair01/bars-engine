  createdAt       DateTime          @default(now())
  deckCard        CampaignDeckCard? @relation(fields: [deckCardId], references: [id])
  period          CampaignPeriod    @relation(fields: [periodId], references: [id], onDelete: Cascade)
  sessions        SpokeSession[]

  @@unique([periodId, slotIndex])
  @@index([campaignRef, periodId])
  @@map("campaign_portals")
}

/// A player's journey through one portal's CYOA spoke.
/// Replaces the retired gameboard completion surface for campaign-spoke play.
model SpokeSession {
  id               String          @id @default(cuid())
  portalId         String
  playerId         String
  campaignRef      String
  moveType         String?
  gmFace           String?
  status           String          @default("in_progress")
  barSeedIds       String          @default("[]")
  generatedQuestId String?
  moveChosenAt     DateTime?
  faceChosenAt     DateTime?
  completedAt      DateTime?
  createdAt        DateTime        @default(now())
  intakeCheckInId  String?
  barSeeds         CustomBar[]     @relation("SpokeBarSeeds")
  npcEncounters    NpcEncounter[]  @relation("NpcEncounters")
  intakeCheckIn    AlchemyCheckIn? @relation("SpokeSessionCheckIn", fields: [intakeCheckInId], references: [id])
  player           Player          @relation("SpokeSessions", fields: [playerId], references: [id], onDelete: Cascade)
  portal           CampaignPortal  @relation(fields: [portalId], references: [id], onDelete: Cascade)

  @@index([portalId, playerId])
  @@index([playerId, status])
  @@index([intakeCheckInId])
  @@map("spoke_sessions")
}

/// SMB — Spoke move seed beds: four throughput slots per (campaignRef, spokeIndex).
model SpokeMoveBed {
  id                   String               @id @default(cuid())
  campaignRef          String               @map("campaign_ref")
  spokeIndex           Int                  @map("spoke_index")
  /// wakeUp | cleanUp | growUp | showUp
  moveType             String               @map("move_type")
  /// Canonical spoke-emitted BAR (usually type vibe) — first mover only
  anchorBarId          String?              @unique @map("anchor_bar_id")
  anchoredByPlayerId   String?              @map("anchored_by_player_id")
  anchoredAt           DateTime?            @map("anchored_at")
  anchorReassignedById String?              @map("anchor_reassigned_by_id")
  anchorReassignedAt   DateTime?            @map("anchor_reassigned_at")
  anchorReassignReason String?              @map("anchor_reassign_reason")
  createdAt            DateTime             @default(now()) @map("created_at")
  updatedAt            DateTime             @updatedAt @map("updated_at")
  additionalKernels    SpokeMoveBedKernel[]
  anchorBar            CustomBar?           @relation("SpokeMoveBedAnchor", fields: [anchorBarId], references: [id])
  anchoredBy           Player?              @relation("SpokeMoveBedAnchoredBy", fields: [anchoredByPlayerId], references: [id])

  @@unique([campaignRef, spokeIndex, moveType])
  @@index([campaignRef, spokeIndex])
  @@map("spoke_move_beds")
}

/// SMB — `campaign_kernel` plants in a move bed (abundance / many trees per bed).
