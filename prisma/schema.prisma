model Instance {
  id                           String                  @id @default(cuid())
  slug                         String                  @unique
  name                         String
  domainType                   String
  theme                        String?
  targetDescription            String?
  wakeUpContent                String?
  showUpContent                String?
  storyBridgeCopy              String?
  campaignRef                  String?
  primaryCampaignDomain        String?
  narrativeKernel              String?
  goalAmountCents              Int?
  currentAmountCents           Int                     @default(0)
  kotterStage                  Int                     @default(1)
  timezone                     String?
  allyshipDomain               String?
  domainDeckCycles             Json                    @default("{}")
  isEventMode                  Boolean                 @default(false)
  stripeOneTimeUrl             String?
  patreonUrl                   String?
  venmoUrl                     String?
  cashappUrl                   String?
  paypalUrl                    String?
  /// Optional label for primary donate CTAs (e.g. "Support the residency")
  donationButtonLabel          String?
  donationPackRateCents        Int?                    @default(100)
  packConfig                   String?
  startDate                    DateTime?
  endDate                      DateTime?
  createdAt                    DateTime                @default(now())
  updatedAt                    DateTime                @updatedAt
  vibeData                     String?
  goalData                     String?
  sourceInstanceId             String?
  parentInstanceId             String?                 @map("parent_instance_id")
  linkedInstanceId             String?                 @map("linked_instance_id")
  kernelBarId                  String?                 @unique
  moveIds                      String                  @default("[]")
  spatialMapId                 String?                 @map("spatial_map_id")
  portalAdventureId            String?
  /// v1 JSON: { v, kotterStage, spokes: [{ hexagramId, changingLines, primaryFace }], updatedAt } — one draw per Kotter stage (campaign hub)
  campaignHubState             Json?
  /// Hub / landing deck shape (52 roster vs 64 lattice). Runtime routing uses canonical spoke index; topology gates slot grid & templates.
  campaignDeckTopology         CampaignDeckTopology    @default(CAMPAIGN_DECK_52) @map("campaign_deck_topology")
  /// WMC admin Deck CYOA wizard — last applied intake JSON (DeckIntakeV1) for reproducible deck generation
  deckAuthoringIntake          Json?
  schoolsAdventureId           String?
  /// CSHE / clothing-swap sub-campaign: organizer intake JSON (SwapEventIntakeV1); null = not using swap-event intake on this instance
  swapEventIntake              Json?                   @map("swap_event_intake")
  /// When set, participants may read published intake (organizers always see latest draft in organizer UI)
  swapEventIntakePublishedAt   DateTime?               @map("swap_event_intake_published_at")
  /// Community Character corpus (v1 JSON) — bingo prompts per campaign instance
  communityCharacterCorpus     Json?                   @map("community_character_corpus")
  /// GM-overridable CYOA Composer step ordering per campaign (JSON)
  composerStepOverrides        Json?
  activeInConfigs              AppConfig[]
  scopedArchetypes             Archetype[]             @relation("ArchetypeInstance")
  barShareExternals            BarShareExternal[]
  campaignInvitations          CampaignInvitation[]
  campaignPeriods              CampaignPeriod[]        @relation("CampaignPeriods")
  campaignPlaybook             CampaignPlaybook?
  campaigns                    Campaign[]              @relation("InstanceCampaigns")
  barsCollapsedFromInstance    CustomBar[]             @relation("BarCollapsedFromInstance")
  deckLibrary                  DeckLibrary?
  demoOrientationLinks         DemoOrientationLink[]
  donations                    Donation[]
  eventArtifacts               EventArtifact[]
  eventCampaigns               EventCampaign[]
  friendshipInvitations        FriendshipInvitation[]
  gameboardSlots               GameboardSlot[]
  exportRequests               InstanceExportRequest[]
  memberships                  InstanceMembership[]
  participations               InstanceParticipation[]
  kernelBar                    CustomBar?              @relation("CampaignKernel", fields: [kernelBarId], references: [id])
  linkedInstance               Instance?               @relation("InstanceLinkedTo", fields: [linkedInstanceId], references: [id])
  instancesLinkedToMe          Instance[]              @relation("InstanceLinkedTo")
  parentInstance               Instance?               @relation("InstanceChildren", fields: [parentInstanceId], references: [id])
  childInstances               Instance[]              @relation("InstanceChildren")
  portalAdventure              Adventure?              @relation("InstancePortalAdventure", fields: [portalAdventureId], references: [id])
  schoolsAdventure             Adventure?              @relation("InstanceSchoolsAdventure", fields: [schoolsAdventureId], references: [id])
  spatialMap                   SpatialMap?             @relation("InstanceSpatialMap", fields: [spatialMapId], references: [id])
  invites                      Invite[]
  latentAllyshipIntakesSpawned LatentAllyshipIntake[]  @relation("AllyshipIntakeSpawnedInstance")
  libraryRequests              LibraryRequest[]
  scopedNations                Nation[]                @relation("NationInstance")
  questThreads                 QuestThread[]
  redemptionPacks              RedemptionPack[]
  schools                      School[]                @relation("SchoolInstance")
  swapEventRsvps               SwapEventRsvp[]

  @@map("instances")
}

/// CSHE Phase B — light RSVP without full onboarding (Partiful remains canonical).
