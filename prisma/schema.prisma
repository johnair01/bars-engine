model Daemon {
  id                 String   @id @default(cuid())
  playerId           String
  name               String
  source             String // 321_wake_up | school | bar
  sourceBarId        String? // when source=bar, the BAR this daemon was grown from
  level              Int      @default(1)
  moveIds            String   @default("[]") // JSON array of NationMove ids
  discoveredAt       DateTime @default(now())
  /// When set, this daemon was awakened from a full 321 flow with persisted session (SN Phase 8).
  shadow321SessionId String?
  /// Bounded JSON: v, finalShadowName, nameResolution, suggestionCount, identityExcerpt, etc.
  innerWorkDigest    Json?
  /// Set when daemon graduates to an NPC (`Player` creatorType agent) at promotion level.
  promotedToPlayerId String?  @unique

  // --- Individuation Engine / Daemon Codex (IE-8) ---
  voice        String? @db.Text
  desire       String? @db.Text
  fear         String? @db.Text
  shadow       String? @db.Text
  /// JSON array of evolution entries (append-only). See lib/daemon-evolution.ts
  evolutionLog String  @default("[]")

  // --- Daemon Move System (DMS-1) ---
  channel        String  @default("METAL") // WOOD | FIRE | EARTH | METAL | WATER
  altitude       String  @default("DISSATISFIED") // DISSATISFIED | NEUTRAL | SATISFIED
  collective     Boolean @default(false)
  communityScope String? // null = individual; instanceId = community scope

  player           Player               @relation(fields: [playerId], references: [id], onDelete: Cascade)
  sourceBar        CustomBar?           @relation("DaemonSourceBar", fields: [sourceBarId], references: [id], onDelete: SetNull)
  shadow321Session Shadow321Session?    @relation(fields: [shadow321SessionId], references: [id], onDelete: SetNull)
  promotedToPlayer Player?              @relation("DaemonPromotedToNpc", fields: [promotedToPlayerId], references: [id], onDelete: SetNull)
  summons          DaemonSummon[]
  moveCreations    DaemonMoveCreation[]

  @@index([playerId])
  @@index([shadow321SessionId])
  @@map("daemons")
}

