  action       String
  targetType   String
  targetId     String
  payloadJson  String?
  createdAt    DateTime @default(now())

  @@map("audit_logs")
}

model GlobalState {
  id               String   @id
  storyClock       Int      @default(0)
  currentAct       Int      @default(1)
  currentPeriod    Int      @default(1)
  isPaused         Boolean  @default(false)
