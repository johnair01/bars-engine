{
  "name": "mtgoa-game",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Mastering the Game of Allyship — digital card game. Migrated from Claude.ai artifact to a standalone Vite + React + TypeScript app.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
