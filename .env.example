# .env.example — copy to `.env` (or `.env.local`) and fill in.
# Docs: docs/ENV_AND_VERCEL.md. With Vercel access, prefer `npm run env:pull`
# (writes .env.local with everything) over copy-paste.
#
# Verify after setting: `npm run smoke` (checks DATABASE_URL + DB reachability),
# then `npm run dev`.

# ─── REQUIRED to run the app / DB ──────────────────────────────────────────────
# Direct PostgreSQL connection string (NOT the Accelerate prisma+postgres:// URL,
# which cannot run migrations). Local dev prefers DATABASE_URL over Accelerate.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public"

# Optional second URL some flows read for the *direct* connection (migrations).
# Set equal to DATABASE_URL if you only have one.
# DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public"

# ─── NOT needed for the Superpower / Mobility Quest flow ───────────────────────
# The superpower quiz, translate matrix, routing, and milestone-needs engine are
# deterministic — no AI key required. Set these only for OTHER AI features.
# OPENAI_API_KEY=""
# ANTHROPIC_API_KEY=""

# ─── Commonly useful (have safe defaults if unset) ─────────────────────────────
# App URLs (used in links/CTAs). Default to localhost in dev.
# NEXT_PUBLIC_APP_URL="http://localhost:3000"
# APP_URL="http://localhost:3000"

# Uploads (BAR photos, book PDFs) via Vercel Blob. Without it, uploads fall back
# to local FS in dev. Not needed for the superpower flow.
# BLOB_READ_WRITE_TOKEN=""

# Entitlement / commerce verification (marketing funnel works without these).
# GUMROAD_VERIFY_MODE="mock"   # "mock" accepts TEST-… keys for local/tests

# ─── Build / migration switches (advanced; see build-with-env.ts) ──────────────
# SKIP_PRISMA_MIGRATE_DEPLOY=1        # build without applying migrations
# VERCEL_RUN_MIGRATE_ON_PREVIEW=1     # apply migrations on Vercel Preview
