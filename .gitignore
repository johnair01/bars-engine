# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
# Typo artifact from bad path (use .specify/ only)
/..specify/
# Python (FastAPI backend)
__pycache__/
*.py[cod]
*$py.class
.Python
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# feedback logs (user-submitted, agent-pulled)
.feedback/

# Transformation simulation harness CLI output (FN)
/simulation-logs/

# Backlog API fetch output (generated)
.specify/backlog/items.json

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# embedded repos (avoid accidental add)
LibreSprite/
.claude/

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# Local SQLite database
*.db
*.db-journal

# Database backups (local cold storage)
/backups/

# Bootstrap output (creation quest analysis)
scripts/bootstrap-creation-quests-output.json

# Uploaded files (books, etc.)
/uploads/
/public/uploads/
.prisma_hash
.env*.local
